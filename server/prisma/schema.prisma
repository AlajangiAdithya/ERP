generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──── USERS & AUTH ────
model User {
  id                         String                     @id @default(uuid())
  username                   String                     @unique
  passwordHash               String
  plainPassword              String?
  name                       String
  role                       Role                       @default(MANAGER)
  unitId                     String?
  unit                       Unit?                      @relation(fields: [unitId], references: [id])
  isActive                   Boolean                    @default(true)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  sessions                   Session[]
  auditLogs                  AuditLog[]
  productRequests            ProductRequest[]
  sentNotifications          Notification[]             @relation("SentBy")
  purchaseRequests           PurchaseRequest[]          @relation("PurchaseRequestManager")
  purchaseRequestApprovals   PurchaseRequest[]          @relation("PurchaseRequestApprover")
  // New relations for procurement workflow
  targetedNotifications      Notification[]             @relation("TargetUser")
  quotationsCreated          Quotation[]                @relation("QuotationCreator")
  quotationsSubmittedToAdmin Quotation[]                @relation("QuotationSubmitter")
  purchaseOrdersCreated      PurchaseOrder[]            @relation("POCreator")
  purchaseOrdersCreditPlaced PurchaseOrder[]            @relation("POCreditPlacer")
  purchaseOrdersClosed       PurchaseOrder[]            @relation("POCloser")
  paymentRequestsCreated     PaymentRequest[]           @relation("PaymentCreator")
  paymentRequestsProcessed   PaymentRequest[]           @relation("PaymentProcessor")
  qcInspections              QCInspection[]             @relation("QCInspector")
  qcInspectionRequests       QCInspection[]             @relation("QCInspectionRequestor")
  gatePassesCreated          GatePass[]                 @relation("GatePassCreator")
  gatePassesSiteApproved     GatePass[]                 @relation("GatePassSiteIncharge")
  gatePassesStoreApproved    GatePass[]                 @relation("GatePassStoreIncharge")
  gatePassesAccountsApproved GatePass[]                 @relation("GatePassAccountsApprover")
  gatePassesFinalApproved    GatePass[]                 @relation("GatePassFinalApprover")
  gatePassesCollected        GatePass[]                 @relation("GatePassCollector")
  fimBatchesAssigned         ProductBatch[]             @relation("FimAssignedBy")
  fimBatchesAccepted         ProductBatch[]             @relation("FimAcceptedBy")
  fimBatchesReadyToSendOut   ProductBatch[]             @relation("FimReadyToSendOutBy")
  ionsCreated                InterOfficeNote[]          @relation("IONCreator")
  ionsAssigned               InterOfficeNote[]          @relation("IONAssignee")
  transferRequestsCreated    InventoryTransferRequest[] @relation("TransferRequester")
  transferRequestsApproved   InventoryTransferRequest[] @relation("TransferApprover")
  workOrdersCreated          WorkOrder[]                @relation("WorkOrderCreator")
  workOrdersAdminAccepted    WorkOrder[]                @relation("WorkOrderAdminAcceptor")
  workOrdersUnitAccepted     WorkOrder[]                @relation("WorkOrderUnitAcceptor")
  workOrderExtensionsGranted WorkOrderExtension[]       @relation("WorkOrderExtensionGranter")
  workOrderInvoicesLogged    WorkOrderInvoice[]         @relation("WorkOrderInvoiceCreator")
  materialPoolsCreated       MaterialPool[]             @relation("MaterialPoolCreator")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  STORE_MANAGER
  PURCHASE_OFFICER
  ACCOUNTING
  QC
  LAB
  METROLOGY
  NDT
  RND
  SAFETY
  SUPPLY_CHAIN
  DESIGNS
  FINANCE
  PLANNING
  LOGISTICS
  // Hidden owner-only role — never appears in UI lists, dashboards, notification
  // broadcasts, approval chains. Has Real-time Corrections + Backups + Audit pages.
  SUPERADMIN
}

// ──── UNITS ────
model Unit {
  id                 String                     @id @default(uuid())
  name               String                     @unique
  code               String                     @unique
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  users              User[]
  productRequests    ProductRequest[]
  purchaseRequests   PurchaseRequest[]
  transfersFrom      InventoryTransferRequest[] @relation("TransferFromUnit")
  transfersTo        InventoryTransferRequest[] @relation("TransferToUnit")
  productStocks      ProductUnitStock[]
  workOrders         WorkOrder[]                @relation("WorkOrderAssignedUnit")
  inwardGatePasses   GatePass[]                 @relation("GatePassDestinationUnit")
  fimBatchesAssigned ProductBatch[]             @relation("FimAssignedToUnit")
}

// ──── AUDIT LOG ────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ──── PRODUCTS / INVENTORY ────
model Product {
  id                   String                     @id @default(uuid())
  name                 String
  sku                  String                     @unique
  // Customer/legacy identification number from the Material Details register
  // (e.g. 1000, 1001, 1501…). Independent of the auto-generated SKU.
  materialCode         String?                    @unique
  description          String?
  category             String?
  unit                 String                     @default("pcs")
  currentStock         Float                      @default(0)
  minStockLevel        Float                      @default(0)
  isActive             Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  stockMovements       StockMovement[]
  requestItems         RequestItem[]
  purchaseRequestItems PurchaseRequestItem[]
  batches              ProductBatch[]
  transfers            InventoryTransferRequest[]
  quotationItems       QuotationItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  unitStocks           ProductUnitStock[]
  materialPools        MaterialPool[]
}

// ──── PER-UNIT INVENTORY (Phase 6) ────
// When a PR is created for a unit and inward is done, product quantity is
// indented to that owning unit. Other units must use InventoryTransferRequest
// to move stock between units.
model ProductUnitStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([productId, unitId])
  @@index([unitId])
}

// ──── PRODUCT BATCHES (FIFO lot tracking) ────
model ProductBatch {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNo       String?
  receivedDate  DateTime @default(now())
  quantity      Float // original inward qty
  remaining     Float // qty still in stock
  unitCost      Float?
  referenceType String? // InwardEntry, PurchaseOrder, InwardEntryNewProduct, InwardGatePass
  referenceId   String?
  notes         String?
  createdById   String?
  createdAt     DateTime @default(now())

  // FIM (Free Issue Material — customer's property) linkage.
  // Set when this batch was inwarded via an INWARD gate pass.
  isFim                      Boolean       @default(false)
  sourceInwardGatePassId     String?
  sourceInwardGatePass       GatePass?     @relation("FimSourceGatePass", fields: [sourceInwardGatePassId], references: [id])
  sourceInwardGatePassItemId String?
  sourceInwardGatePassItem   GatePassItem? @relation("FimSourceItem", fields: [sourceInwardGatePassItemId], references: [id])

  // FIM unit-assignment + one-shot acceptance (no MIV needed for FIM).
  // Stores assigns a FIM batch to a unit; the unit manager clicks Accept + remark; final.
  assignedToUnitId    String?
  assignedToUnit      Unit?     @relation("FimAssignedToUnit", fields: [assignedToUnitId], references: [id])
  assignedAt          DateTime?
  assignedById        String?
  assignedBy          User?     @relation("FimAssignedBy", fields: [assignedById], references: [id])
  unitAcceptedAt      DateTime?
  unitAcceptedById    String?
  unitAcceptedBy      User?     @relation("FimAcceptedBy", fields: [unitAcceptedById], references: [id])
  unitAcceptedRemarks String?

  // Two-step return: unit manager marks the FIM ready to send back to the customer,
  // then Stores actually creates the outward gate pass. Stores cannot send out
  // until readyToSendOutAt is set.
  readyToSendOutAt   DateTime?
  readyToSendOutById String?
  readyToSendOutBy   User?     @relation("FimReadyToSendOutBy", fields: [readyToSendOutById], references: [id])
  readyToSendOutNote String?

  // PO-flow lot linkage: which QC inspection (lot) this batch came from.
  // Lets the product list show PR → PO → Lot N (invoice) → Batch chain.
  sourceQcInspectionId String?
  sourceQcInspection   QCInspection? @relation("BatchSourceInspection", fields: [sourceQcInspectionId], references: [id])

  @@index([productId, receivedDate])
  @@index([productId, remaining])
  @@index([sourceInwardGatePassItemId])
  @@index([sourceQcInspectionId])
}

// ──── STOCK MOVEMENTS ────
model StockMovement {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  type          MovementType
  quantity      Float
  referenceType String?
  referenceId   String?
  batchNumber   String?
  notes         String?
  performedBy   String?
  unitId        String?
  createdAt     DateTime     @default(now())
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

// ──── PRODUCT REQUESTS / MIV (Requester → Store Manager workflow) ────
// Form No: RAPS/MIV/REV01 Dt: 01/02/2025
model ProductRequest {
  id             String        @id @default(uuid())
  requestNumber  String        @unique
  referenceNo    String? // Reference No. & Date (from MIV form)
  mirNo          String? // MIR NO. (from MIV form)
  issueNo        String? // Issue No.
  issueDate      DateTime? // Issue Date
  managerId      String?
  manager        User?         @relation(fields: [managerId], references: [id], onDelete: SetNull)
  unitId         String
  unit           Unit          @relation(fields: [unitId], references: [id])
  status         RequestStatus @default(PENDING)
  notes          String?
  remarks        String? // Remarks field from MIV form
  clearanceNotes String?
  clearedById    String?
  clearedAt      DateTime?
  collectedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          RequestItem[]
}

model RequestItem {
  id              String         @id @default(uuid())
  requestId       String
  request         ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Float
  approvedQty     Float?
  collectedQty    Float          @default(0) // cumulative qty actually taken (partial collection)
  purpose         String? // Purpose (Production fills)
  qtyIssued       Float? // Qty Issue (Store fills)
  materialBatchNo String? // Material Batch No. If any (Store fills)
}

enum RequestStatus {
  PENDING
  APPROVED
  PARTIAL
  REJECTED
  COLLECTED
  CANCELLED
}

// ──── PURCHASE REQUESTS (Requester → Admin → PO → Quotation → Order workflow) ────
model PurchaseRequest {
  id                   String                @id @default(uuid())
  requestNumber        String                @unique
  requestId            String? // Legacy order-name column (kept for backward compat; new PRs leave this null and use requestNumber as the identifier)
  managerId            String?
  manager              User?                 @relation("PurchaseRequestManager", fields: [managerId], references: [id], onDelete: SetNull)
  unitId               String
  unit                 Unit                  @relation(fields: [unitId], references: [id])
  status               PurchaseRequestStatus @default(PENDING_ADMIN)
  notes                String?
  materialSpecsPdfUrl  String? // Optional material specs PDF attached at PR creation
  adminNotes           String?
  adminApprovedById    String?
  adminApprovedBy      User?                 @relation("PurchaseRequestApprover", fields: [adminApprovedById], references: [id])
  adminApprovedAt      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  items                PurchaseRequestItem[]
  quotations           Quotation[]
  purchaseOrders       PurchaseOrder[]
  quotationSources     QuotationSource[]
  purchaseOrderSources PurchaseOrderSource[]
}

// Form No: RAPS/PRF Rev no. 02 Date: 31/08/2024
model PurchaseRequestItem {
  id                     String                        @id @default(uuid())
  requestId              String
  request                PurchaseRequest               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId              String?
  product                Product?                      @relation(fields: [productId], references: [id])
  productName            String // Material Description
  productUnit            String                        @default("pcs") // UOM
  requestedQty           Float // Required Quantity
  adminApprovedQty       Float?
  purchasedQty           Float                         @default(0)
  itemStatus             ItemOrderStatus? // Set once ORDER_PLACED; mirrored from PO items
  itemQuotationStatus    PRItemQuotationStatus         @default(AWAITING_QUOTATION) // Per-item quote progress, independent of order/inward status
  // PRF form fields
  materialType           String? // Raw material / Consumable / Hand Tools & Fastners / Tools & Fixtures / Others
  materialSpecification  String? // Material specification data
  // Optional confidential material-spec PDF attached at PR creation time.
  // Shown as a "View spec" link in PR views; merged after the PR body in the
  // downloaded PR PDF; surfaced to QC alongside the source PR.
  specAttachmentUrl      String?
  specAttachmentName     String?
  qapNo                  String? // QAP no. & QAP attachment reference
  drawingNo              String? // Drawing no. & detailed drawing reference
  materialRequiredFor    String? // SO no. / R&D
  internalWorkOrder      String? // Internal Work Order (free text)
  purpose                String? // Purpose
  sourceOfSupply         String? // Source of supply if any
  scopeOfWork            String? // Reports Required / Scope of Work
  inspectionType         String? // Inhouse / External (RAPS QC/Customer QC)
  requiredByDate         DateTime? // Required by date
  itemRemarks            String? // Other details/Remarks
  poItemAllocations      PurchaseOrderItemAllocation[]
  materialPoolMembership MaterialPoolItem?
}

enum PurchaseRequestStatus {
  PENDING_ADMIN
  APPROVED
  QUOTATION_SUBMITTED
  QUOTATION_APPROVED
  ORDER_PLACED
  GOODS_ARRIVED
  QC_PASSED
  INWARD_DONE
  COMPLETED
  REJECTED
  IN_PROGRESS
}

// Per-PR-item quotation progress. Independent of `itemStatus` (which mirrors
// downstream PO/inward state). Lets the UI render fine-grained badges like
// "Quotation not sent yet" for items still missing supplier quotes while
// other items on the same PR have already moved into POs.
enum PRItemQuotationStatus {
  AWAITING_QUOTATION
  QUOTATION_SUBMITTED
  QUOTATION_HELD
  QUOTATION_APPROVED
  CANCELLED
}

// ──── SUPPLIERS (normalised supplier directory) ────
// Quotation/PO rows still snapshot supplierName/Contact/Address so historical
// records survive supplier renames. The supplierId FK is for lookups + history.
model Supplier {
  id                         String              @id @default(uuid())
  // Vendor ID auto-generated as RAPS/SUP/<NNNN>. Sequential across all FY.
  vendorIdNo                 String?             @unique
  name                       String              @unique
  // Legacy single-line contact retained; new format splits into person + phone.
  contact                    String?
  contactPerson              String?
  contactPhone               String?
  address                    String?
  gstNumber                  String?
  email                      String?
  isActive                   Boolean             @default(true)
  notes                      String?
  // Approved Supplier List columns (client format).
  scopeOfSupply              String?
  materialType               SupplierMaterialType?
  approvalStatus             SupplierApprovalStatus?
  approvalDate               DateTime?
  typeAndExtentOfControl     String?
  remarks                    String?
  // Vendor Evaluation PDF — uploaded once when the supplier is first onboarded.
  // Survives FY data resets; never re-required.
  vendorEvaluationPdfUrl     String?
  vendorEvaluationUploadedAt DateTime?
  // Supplier Assessment PDF — valid only for the financial year stored in
  // `assessmentFiscalYear`. After FY rollover, a new assessment must be uploaded
  // before the supplier can be used on a new quotation.
  supplierAssessmentPdfUrl   String?
  assessmentFiscalYear       String?
  assessmentUploadedAt       DateTime?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  quotations                 Quotation[]
  quotationItems             QuotationItem[]
  purchaseOrders             PurchaseOrder[]
  purchaseOrderItems         PurchaseOrderItem[]
  reEvaluations              SupplierReEvaluation[]
  assessmentForms            SupplierAssessmentForm[]
  performanceRatings         SupplierPerformanceRatingItem[]
}

enum SupplierMaterialType {
  MATERIAL
  JOB_WORK
  SERVICE
}

enum SupplierApprovalStatus {
  APPROVED
  CONDITIONAL
  REJECTED
  TERMINATED
}

// ──── SUPPLIER RE-EVALUATION (one row per review event) ────
// Drives the "Evaluation Details" panel in the Approved Supplier List.
// Snapshot of the printable Supplier Re-Evaluation Form. The latest record per
// (supplier, financialYear) is what the master list shows.
model SupplierReEvaluation {
  id                          String     @id @default(uuid())
  supplierId                  String
  supplier                    Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  financialYear               String     // e.g. "26-27"
  initialEvaluationDate       DateTime?
  initialEvaluationScope      String?    // Product / Process / Service text
  // YES/NO criteria — nullable boolean so "not answered" is distinct from NO.
  noOrders6Months             Boolean?
  noOrdersReason              String?
  managementChanged           Boolean?
  newMgmtContinuingTerms      Boolean?
  shiftedLocation             Boolean?
  newAddress                  String?
  performanceBelowPar         Boolean?
  correctiveActionInitiated   String?    // free-text: instructions given
  recommendedTermination      Boolean?
  correctiveActionEffective   Boolean?
  noNonconformitiesReported   Boolean?
  newMachinesAdded            Boolean?
  wishToContinueForNewParts   Boolean?
  isoCertified                Boolean?
  // Outcome.
  overallDecision             SupplierReEvalDecision @default(CONTINUES)
  // Schedule.
  evaluationDate              DateTime?
  nextReviewDate              DateTime?
  // Performance score copied from the latest performance rating, or entered
  // manually. Shown in the "Performance Rating after review" column.
  performanceRating           Float?
  remarks                     String?
  evaluatedByUserId           String?
  evaluatedByName             String?    // snapshot in case the user is renamed
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  @@index([supplierId])
  @@index([supplierId, financialYear])
}

enum SupplierReEvalDecision {
  CONTINUES
  TERMINATED
}

// ──── STRUCTURED VENDOR / SUPPLIER ASSESSMENT FORM ────
// Captured during onboarding (or re-captured if vendor profile changes). The
// existing supplierAssessmentPdfUrl is kept as an optional fallback / scan.
model SupplierAssessmentForm {
  id                       String     @id @default(uuid())
  supplierId               String
  supplier                 Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  financialYear            String     // FY the form was submitted under
  companyName              String?
  companyAddress           String?
  businessType             SupplierBusinessType?
  businessRole             SupplierBusinessRole?
  productsRange            String?
  machineryAndEquipment    String?
  majorCustomers           String?
  transportFacilities      String?
  deliveryPeriod           String?
  allowsCapabilityVerify   Boolean?
  hasQualityControlSystem  Boolean?
  isoCertified             Boolean?
  isoCertificateUrl        String?
  testCertWithDelivery     Boolean?
  readyToUpgradePerformance Boolean?
  reviewComments           String?
  reviewedByName           String?
  reviewedByUserId         String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([supplierId])
  @@index([supplierId, financialYear])
}

enum SupplierBusinessType {
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LTD
  PUBLIC_LTD
}

enum SupplierBusinessRole {
  MANUFACTURER
  SUPPLIER
  DEALER
}

// ──── SUPPLIER PERFORMANCE RATING (FY-bucketed scorecard) ────
// Header carries the period and overall summary; one row per (item, supplier)
// in items. Mirrors the printable rating sheet — the overall % is recomputed
// from item rows on every write.
model SupplierPerformanceRating {
  id              String                          @id @default(uuid())
  financialYear   String                          // e.g. "24-25"
  periodFrom      DateTime?
  periodTo        DateTime?
  preparedDate    DateTime?
  preparedByName  String?
  preparedByUserId String?
  minimumCriteria Float                           @default(85)
  overallRating   Float?                          // computed from items
  remarks         String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  items           SupplierPerformanceRatingItem[]

  @@unique([financialYear])
  @@index([financialYear])
}

model SupplierPerformanceRatingItem {
  id                       String                     @id @default(uuid())
  ratingId                 String
  rating                   SupplierPerformanceRating  @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  supplierId               String?
  supplier                 Supplier?                  @relation(fields: [supplierId], references: [id])
  itemDescription          String
  supplierName             String
  suppliesReceived         Int                        @default(0)
  qtyAccepted              Int                        @default(0)
  qualityRating            Float                      @default(0)  // out of 60
  totalDeliveries          Int                        @default(0)
  deliveriesOnTime         Int                        @default(0)
  deliveriesLate           Int                        @default(0)
  deliveryRating           Float                      @default(0)  // out of 40
  totalRating              Float                      @default(0)  // out of 100
  createdAt                DateTime                   @default(now())

  @@index([ratingId])
  @@index([supplierId])
}

// ──── MATERIAL POOLS (PO bundles same-material lines across PRs before quoting) ────
// A pool groups ≥2 PurchaseRequestItems that share a material so the PO can
// collect competing quotes covering all of them at once. Pool membership is
// orthogonal to itemQuotationStatus — a pooled item stays AWAITING_QUOTATION
// until a union quotation tied to the pool gets submitted. When that quote is
// approved, the pool flips to APPROVED and the underlying PR-items follow the
// union PO's allocation chain (PurchaseOrderItemAllocation) for FIFO inward.
model MaterialPool {
  id          String             @id @default(uuid())
  productId   String?
  product     Product?           @relation(fields: [productId], references: [id])
  productName String
  productUnit String             @default("pcs")
  status      MaterialPoolStatus @default(OPEN)
  createdById String
  createdBy   User               @relation("MaterialPoolCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       MaterialPoolItem[]

  @@index([status])
  @@index([productId])
}

model MaterialPoolItem {
  id                    String              @id @default(uuid())
  poolId                String
  pool                  MaterialPool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  purchaseRequestItemId String              @unique
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id], onDelete: Cascade)
  pooledAt              DateTime            @default(now())

  @@index([poolId])
}

enum MaterialPoolStatus {
  OPEN // accepting union quotations
  QUOTED // ≥1 union quotation submitted to admin
  APPROVED // one union quotation approved → PO live
  CANCELLED // pool dissolved
}

// ──── QUOTATIONS (PO collects from suppliers) ────
model Quotation {
  id                      String            @id @default(uuid())
  quotationNumber         String            @unique
  purchaseRequestId       String?
  purchaseRequest         PurchaseRequest?  @relation(fields: [purchaseRequestId], references: [id])
  isUnion                 Boolean           @default(false)
  supplierId              String?
  supplier                Supplier?         @relation(fields: [supplierId], references: [id])
  supplierName            String?
  supplierContact         String?
  supplierAddress         String?
  totalAmount             Float
  notes                   String?
  quotationPdfUrl         String? // Optional supplier-quote PDF uploaded by PO
  selectionNote           String? // Admin's note explaining why this quote was chosen
  isSelected              Boolean           @default(false)
  holdNote                String? // Admin's reason for putting the quotation on hold (compliance docs missing, etc.)
  heldAt                  DateTime? // Timestamp when admin put this quotation on hold
  // PO must explicitly send the batch to admin before admin can see/approve it.
  // Null = still in PO draft; non-null = visible to admin for review.
  submittedToAdminAt      DateTime?
  submittedToAdminById    String?
  submittedToAdmin        User?             @relation("QuotationSubmitter", fields: [submittedToAdminById], references: [id])
  // Set when admin approves a competing quote on the same coverage — soft-archives
  // this quote so it disappears from the queue but stays for supplier-price history.
  supersededAt            DateTime?
  supersededByQuotationId String?
  supersededBy            Quotation?        @relation("QuotationSuperseded", fields: [supersededByQuotationId], references: [id])
  superseded              Quotation[]       @relation("QuotationSuperseded")
  createdById             String
  createdBy               User              @relation("QuotationCreator", fields: [createdById], references: [id])
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  items                   QuotationItem[]
  purchaseOrders          PurchaseOrder[]
  sourceRequests          QuotationSource[]
}

// Junction: links a union Quotation to its source PurchaseRequests
model QuotationSource {
  id                String          @id @default(uuid())
  quotationId       String
  quotation         Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([quotationId, purchaseRequestId])
}

model QuotationItem {
  id                String    @id @default(uuid())
  quotationId       String
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?  @relation(fields: [productId], references: [id])
  productName       String
  productUnit       String    @default("pcs")
  quantity          Float
  unitPrice         Float
  totalPrice        Float
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  supplierName      String
  supplierContact   String?
  supplierAddress   String?
  // For union quotations: per-PR-item allocation breakdown captured at quotation creation
  // so it can be carried into PurchaseOrderItemAllocation when the quotation is approved.
  // Shape: [{ purchaseRequestItemId: string, allocatedQty: number }]
  sourceAllocations Json?
}

// ──── PURCHASE ORDERS (created when quotation is selected) ────
model PurchaseOrder {
  id                String                @id @default(uuid())
  orderNumber       String                @unique
  customName        String
  purchaseRequestId String?
  purchaseRequest   PurchaseRequest?      @relation(fields: [purchaseRequestId], references: [id])
  isUnion           Boolean               @default(false)
  quotationId       String
  quotation         Quotation             @relation(fields: [quotationId], references: [id])
  supplierId        String?
  supplier          Supplier?             @relation(fields: [supplierId], references: [id])
  supplierName      String
  totalAmount       Float
  advancePaid       Float                 @default(0)
  totalPaid         Float                 @default(0)
  goodsArrived      Boolean               @default(false)
  goodsArrivedAt    DateTime?
  delayNote         String? // Optional note when PO placed ≥3 days after PR creation
  mirNo             String? // Auto-generated at stores inward (MIR-YYYYMMDD-NNN)
  inwardedAt        DateTime? // Timestamp of stores inward
  // Signed PO PDF uploaded by Purchase Officer after the quotation is approved.
  // This is the single source of truth for the PO document — no auto-generated PDF is offered.
  poDocumentUrl     String?
  status            PurchaseOrderStatus   @default(PENDING_ACCOUNTING)
  // Credit-based order placement: PO Officer can place order on word-of-trust
  // before payment is processed. Order proceeds, payment follows later.
  isCreditOrder     Boolean               @default(false)
  creditPlacedAt    DateTime?
  creditPlacedById  String?
  creditPlacedBy    User?                 @relation("POCreditPlacer", fields: [creditPlacedById], references: [id])
  creditNote        String?
  // Manual close — Purchase Officer clicks "Close PO" once everything is received & paid.
  // Force-close is allowed with `forceClosed=true` when some qty is still pending or payment is short;
  // in that case leftover PR items are cancelled.
  closedAt          DateTime?
  closedById        String?
  closedBy          User?                 @relation("POCloser", fields: [closedById], references: [id])
  closeReason       String?
  forceClosed       Boolean               @default(false)
  createdById       String
  createdBy         User                  @relation("POCreator", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  items             PurchaseOrderItem[]
  paymentRequests   PaymentRequest[]
  qcInspections     QCInspection[]
  sourceRequests    PurchaseOrderSource[]
}

// Junction: links a union PurchaseOrder to its source PurchaseRequests
model PurchaseOrderSource {
  id                String          @id @default(uuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([purchaseOrderId, purchaseRequestId])
}

model PurchaseOrderItem {
  id                    String                        @id @default(uuid())
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder                 @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId             String?
  product               Product?                      @relation(fields: [productId], references: [id])
  productName           String
  productUnit           String                        @default("pcs")
  quantity              Float
  unitPrice             Float
  totalPrice            Float
  receivedQty           Float                         @default(0)
  itemStatus            ItemOrderStatus               @default(WAITING)
  purchaseRequestItemId String?
  supplierId            String?
  supplier              Supplier?                     @relation(fields: [supplierId], references: [id])
  statusUpdatedAt       DateTime?
  statusUpdatedBy       String?
  allocations           PurchaseOrderItemAllocation[]
  inspectionItems       QCInspectionItem[]
}

// For union PO items: tracks per-PR-item allocation of the consolidated quantity.
// Non-union items leave this empty and use PurchaseOrderItem.purchaseRequestItemId.
model PurchaseOrderItemAllocation {
  id                    String              @id @default(uuid())
  purchaseOrderItemId   String
  purchaseOrderItem     PurchaseOrderItem   @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  purchaseRequestItemId String
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id])
  allocatedQty          Float
  receivedQty           Float               @default(0)
  createdAt             DateTime            @default(now())

  @@unique([purchaseOrderItemId, purchaseRequestItemId])
}

enum ItemOrderStatus {
  WAITING
  ORDERED
  ON_THE_WAY
  RECEIVED
  CANCELLED
}

enum PurchaseOrderStatus {
  PENDING_ACCOUNTING
  CREDIT_PLACED
  ORDERED
  PLACED
  ADVANCE_PAID
  PAYMENT_PENDING
  PAID
  GOODS_ARRIVED
  QC_PENDING
  QC_PASSED
  QC_FAILED
  PARTIAL
  INWARD_DONE
  COMPLETED
  CLOSED
}

// ──── PAYMENT REQUESTS (PO → Accounting) ────
model PaymentRequest {
  id              String               @id @default(uuid())
  paymentNumber   String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  amount          Float
  paymentType     PaymentType
  status          PaymentRequestStatus @default(PENDING)
  notes           String?
  processedById   String?
  processedBy     User?                @relation("PaymentProcessor", fields: [processedById], references: [id])
  processedAt     DateTime?
  createdById     String
  createdBy       User                 @relation("PaymentCreator", fields: [createdById], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// ──── QC INSPECTIONS ────
// Form No: RAPS/IIR Rev 01, Dt: 01/09/2024 (Inward Inspection Request + Report)
model QCInspection {
  id                   String             @id @default(uuid())
  inspectionNumber     String             @unique // ION No.
  purchaseOrderId      String
  purchaseOrder        PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  result               QCResult           @default(PENDING)
  parameters           Json? // Flexible inspection parameters
  notes                String?
  requestCreatedById   String? // Who created the inspection request (Purchase/Stores)
  requestCreatedBy     User?              @relation("QCInspectionRequestor", fields: [requestCreatedById], references: [id])
  inspectedById        String? // Who filled the inspection report (QC)
  inspectedBy          User?              @relation("QCInspector", fields: [inspectedById], references: [id])
  inspectedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  // ── Page 1: Inward Inspection Request fields ──
  invoiceNo            String? // 11. Invoice no. & date
  invoiceDate          DateTime?
  dcNo                 String? // 12. DC no. if any
  gatePassNo           String? // 13. Gate pass no. (FIM/Others)
  gatePassType         String? // 14. Gate pass type
  probableDateOfReturn DateTime? // 15. Probable date of Return
  materialReceiptDate  DateTime? // 16. Material receipt date @ RAPS Store
  // ── Page 2: Inward Inspection Report fields ──
  reportNo             String? // Inspection report no.
  reportDate           DateTime?
  materialDescription  String? // Material description and specification
  materialCategory     String? // Raw materials / Consumables / Tooling & Fixtures / FIM
  documentTypes        Json? // Checkboxes: Test Report, COC, COA, 3rd Party/Customer Clearance
  // ── Phase 4: PO-driven inspection request + QC re-review flow ──
  docRequirement       String? // COA / COC / ANY_REPORTS chosen at inspection request
  docRequirementNote   String? // Free text note alongside docRequirement
  uploadedDocs         Json? // Array of {filename, url, uploadedById, uploadedAt} from PO
  pendingReason        String? // Reason QC marked Pending; bounces back to PO
  iteration            Int                @default(1) // Increment each re-review cycle
  inspectionLocation   String? // Dimensional Inspection at Supplier Place / at RAPS Inward
  reportReferenceNo    String? // Report reference no.
  packingCondition     String? // Sealed / Broken
  packingDamageNotes   String? // If damages, mention
  batchNo              String? // Batch no./Identification
  dateOfManufacturing  DateTime? // Date of manufacturing
  dateOfExpiry         DateTime? // Date of Expiry
  tappedHolesCondition String? // Check condition of tapped holes, weld lugs
  // Quantity tracking
  qtyAsPerPR           Float? // Quantity as per PR
  qtyOrdered           Float? // Quantity ordered
  qtyReceived          Float? // Quantity Received
  qtyAccepted          Float? // Quantity Accepted
  qtyRejected          Float? // Quantity Rejected
  rejectionReason      String? // Reason for Rejection/Non conformity
  remarks              String? // Remarks
  mirNo                String? // MIR No. (Store to be filled)
  // ── Per-lot delivery tracking ──
  // Lot number scoped per PO: 1st lot = 1, 2nd = 2, ... Set on creation.
  lotNumber            Int?
  // Total qty arrived in this lot (sum of items[].arrivedQty)
  arrivedQty           Float?
  // Invoice PDF uploaded by Purchase Officer for this specific lot
  invoiceFileUrl       String?
  // Per-item arrived qty rows for this lot
  items                QCInspectionItem[]
  // Batches inwarded against this lot (FIFO traceability)
  batches              ProductBatch[]     @relation("BatchSourceInspection")
}

// Per-item arrived qty for a specific lot (QCInspection).
// Allows "Lot 1: Item A 400kg, Item B 100kg" attribution.
model QCInspectionItem {
  id                  String            @id @default(uuid())
  inspectionId        String
  inspection          QCInspection      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  arrivedQty          Float
  createdAt           DateTime          @default(now())

  @@index([inspectionId])
  @@index([purchaseOrderItemId])
}

enum QCResult {
  PENDING
  PASSED
  FAILED
  PARTIAL
  ON_HOLD
}

// ──── GATE PASS REQUEST (RAMS/GPR/01) ────
// Workflow: Unit Manager (Site Incharge) → Store Incharge → Accounts → Final Approval
// Approved passes can later be marked RETURNED (returnable items) or CLOSED.
model GatePass {
  id                   String             @id @default(uuid())
  passNumber           String             @unique // Doc/Request No
  // FIM/Customer Property Register number (INWARD STORES only).
  // Format: RAPS/FIM/<FY>/<N>. Distinct from passNumber (RAPS/GP/...) so the
  // FIM register can list entries by their own running count.
  fimNumber            String?            @unique
  // INWARD-only: cross-reference to an internal gate-pass requisition number
  // (the requisitioner's reference for this FIM intake).
  gpRequisitionNo      String?
  passType             GatePassType? // Dominant / legacy type (per-item overrides)
  direction            GatePassDirection  @default(OUTWARD) // INWARD = customer → us, OUTWARD = us → customer/site
  date                 DateTime           @default(now())
  siteName             String? // Site (header)
  partyName            String? // Auto-derived from items.dispatchedTo (legacy column)
  partyContact         String?
  // INWARD-only: details from the customer's own gate pass document
  customerName         String?
  customerGatePassNo   String? // customer's gate pass number (their format, not RAPS)
  customerGatePassDate DateTime?
  customerContact      String? // Deprecated — no longer collected; kept for legacy rows.
  // INWARD-only: document type of the customer's gate pass (ORIGINAL or DUPLICATE)
  // and an uploaded PDF of the customer's GP document.
  customerGpDocType    CustomerGpDocType?
  customerGpPdfUrl     String?
  // INWARD only: how the material is being inwarded.
  // STORES = goes through the From-Gatepass acceptance into the product list (existing flow).
  // DIRECT_TO_UNIT = sent straight to a unit; that unit's manager marks it Collected on the gatepass itself.
  inwardKind           InwardKind?
  destinationUnitId    String?
  destinationUnit      Unit?              @relation("GatePassDestinationUnit", fields: [destinationUnitId], references: [id])
  collectedAt          DateTime?
  collectedById        String?
  collectedBy          User?              @relation("GatePassCollector", fields: [collectedById], references: [id])
  vehicleNo            String? // Filled by Store Incharge when arranging the vehicle
  driverName           String? // Filled by Store Incharge when arranging the vehicle
  invoiceNo            String?
  dcNo                 String?
  purpose              String? // Legacy (now per-item)
  status               GatePassStatus     @default(PENDING_STORE)
  expectedReturnDate   DateTime? // Legacy (now per-item)
  actualReturnDate     DateTime?
  returnedBy           String?
  issuedToName         String?
  issuedToDept         String?
  requisitionNo        String?
  remarks              String?
  rejectedReason       String?

  // Approval trail
  siteInchargeById  String?
  siteInchargeAt    DateTime?
  storeInchargeById String?
  storeInchargeAt   DateTime?
  accountsById      String?
  accountsAt        DateTime?
  approvedById      String?
  approvedAt        DateTime?

  createdById      String
  createdBy        User   @relation("GatePassCreator", fields: [createdById], references: [id])
  siteIncharge     User?  @relation("GatePassSiteIncharge", fields: [siteInchargeById], references: [id])
  storeIncharge    User?  @relation("GatePassStoreIncharge", fields: [storeInchargeById], references: [id])
  accountsApprover User?  @relation("GatePassAccountsApprover", fields: [accountsById], references: [id])
  finalApprover    User?  @relation("GatePassFinalApprover", fields: [approvedById], references: [id])

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     GatePassItem[]

  // FIM linkage: batches that were inwarded from this (INWARD) gate pass
  fimBatches ProductBatch[] @relation("FimSourceGatePass")
}

model GatePassItem {
  id                   String        @id @default(uuid())
  gatePassId           String
  gatePass             GatePass      @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  description          String // Name of components
  quantity             Float         @default(1)
  unit                 String        @default("pcs")
  // Per-row fields matching RAMS/GPR/01
  dispatchedTo         String?
  itemPurpose          String?
  probableReturnDate   DateTime?
  itemPassType         GatePassType?
  gatePassDetails      String?
  transportation       String?
  contactPersonDetails String?
  remarks              String? // Legacy

  // INWARD bookkeeping: how much of this item has been accepted into stores / made into a Product
  inwardedQty Float @default(0)

  // OUTWARD Delivery Challan linkage: if this item is FIM going back to the
  // customer, point to the originating INWARD GatePassItem so the cycle closes.
  sourceInwardGatePassItemId String?
  sourceInwardGatePassItem   GatePassItem?  @relation("InwardOutwardLink", fields: [sourceInwardGatePassItemId], references: [id])
  outwardLinkedItems         GatePassItem[] @relation("InwardOutwardLink")

  // FIM batches created from this INWARD item
  fimBatches ProductBatch[] @relation("FimSourceItem")
}

enum GatePassType {
  RETURNABLE
  NON_RETURNABLE
  DELIVERY_CHALLAN
}

enum GatePassDirection {
  INWARD
  OUTWARD
}

enum InwardKind {
  STORES
  DIRECT_TO_UNIT
}

enum CustomerGpDocType {
  ORIGINAL
  DUPLICATE
}

enum GatePassStatus {
  DRAFT
  PENDING_STORE
  PENDING_ACCOUNTS
  PENDING_APPROVAL
  PENDING_ACCEPTANCE // INWARD-only: customer's material arrived, awaiting stores to inward into products
  ACCEPTED // INWARD-only: stores has inwarded items into products list
  APPROVED
  RETURNED
  CLOSED
  REJECTED
  // Legacy
  OPEN
}

// ──── INTER OFFICE NOTE (ION) — MANAGER ↔ LAB / METROLOGY / NDT workflows ────
// Standard form: Doc No RAMS/ION/00 (LAB / METROLOGY / cross-unit MANAGER).
// NDT variant:  Doc No RAPS/ION-7 — adds qty + per-activity sub-details (UT/RT/VT).
model InterOfficeNote {
  id                 String    @id @default(uuid())
  ionNumber          String    @unique
  userReferenceNo    String?
  section            String?
  projectName        String?
  supplyOrderNo      String?
  referenceDocQA     String?
  materialSupplyDate DateTime?
  sampleRequired     Boolean   @default(false)
  reportGeneration   Boolean   @default(false)
  requiredByDate     DateTime?
  completedDate      DateTime?
  externalQAWitness  String?
  qcContactDetails   String?
  otherInformation   String?
  reportNoAndDate    String? // NDT only: "Report No & Date" closing field
  status             IONStatus @default(SENT)
  recipientRole      String?   @default("LAB") // LAB | METROLOGY | NDT | RND | DESIGNS (when not assigned to a specific manager)
  createdById        String
  createdBy          User      @relation("IONCreator", fields: [createdById], references: [id])
  assignedToId       String?
  assignedTo         User?     @relation("IONAssignee", fields: [assignedToId], references: [id])
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  items              IONItem[]
}

model IONItem {
  id                  String          @id @default(uuid())
  ionId               String
  ion                 InterOfficeNote @relation(fields: [ionId], references: [id], onDelete: Cascade)
  jobIdentification   String
  activityRequired    String?
  materialComposition String?
  drawingNo           String?
  specification       String?
  // NDT extras (RAPS/ION-7). Left nullable so the standard form is unaffected.
  nameOfJob           String?
  qty                 String?
  itemRemarks         String?
  ndtDetails          Json? // { method, gridSize, gridPoints, stage, acceptanceLimit, shotType, shotCount, acceptanceCriteria }
}

enum IONStatus {
  SENT
  WAITING
  COLLECTED
}

// ──── INVENTORY TRANSFER REQUEST (unit-to-unit stock transfers) ────
model InventoryTransferRequest {
  id              String         @id @default(uuid())
  transferNumber  String         @unique
  fromUnitId      String
  fromUnit        Unit           @relation("TransferFromUnit", fields: [fromUnitId], references: [id])
  toUnitId        String
  toUnit          Unit           @relation("TransferToUnit", fields: [toUnitId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Float
  reason          String?
  status          TransferStatus @default(PENDING)
  requestedById   String
  requestedBy     User           @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?          @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  completedAt     DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}

// ──── WORK ORDERS (SUPPLY_CHAIN drafts → ADMIN accepts → UNIT executes) ────
// Doc No: RAPS/WO/01. Mirrors the printable Work Order form (ION header).
// SUPPLY_CHAIN records the customer's external Supply Order + drafts a Work Order.
// ADMIN reviews + accepts (acceptance form). On acceptance the WO is assigned to
// a unit; that unit's MANAGER accepts and starts execution. Delivery progress is
// tracked via per-invoice qty entries; on-time % is computed from PDC (latest
// extension wins) vs. completion date.
model WorkOrder {
  id                     String                  @id @default(uuid())
  // Auto-generated internal Work Order number — RAPS/WO/<FY>/<N>
  workOrderNumber        String                  @unique
  // ION header number on the printable form — RAPS/<UNIT>/<FY>/<N>. Auto.
  ionNumber              String?                 @unique

  // ── External Supply Order (customer's reference) ──
  supplyOrderNo          String
  supplyOrderDate        DateTime
  supplyOrderDescription String?

  // ── Customer ──
  customerName           String
  customerContact        String?

  // ── Order details ──
  orderQuantity          Float
  orderUnit              String                  @default("Nos")
  pdcDate                DateTime                // Primary delivery commitment date
  deliveryClause         String?

  // ── Scope / specs ──
  fimDetails             String?
  inspectionAgency       String?
  qapNo                  String?
  drawingsDetails        String?
  processDrawingsDetails String?
  toolingScope           String?                 // RAPS scope / Customer scope
  packingDetails         String?
  transportationDetails  String?
  majorWorksAtSite       String?                 // e.g. "Unit-5"
  projectCoordinator     String?
  otherInformation       String?
  orderTermsAndScope     String?
  remarks                String?

  // ── Bank Guarantee ──
  bankGuaranteeNo        String?
  bankGuaranteeDate      DateTime?

  // ── Insurance ──
  insuranceNo            String?
  insuranceDate          DateTime?

  // ── Unit assignment + acceptance ──
  assignedUnitId         String?
  assignedUnit           Unit?                   @relation("WorkOrderAssignedUnit", fields: [assignedUnitId], references: [id])
  unitAcceptedAt         DateTime?
  unitAcceptedById       String?
  unitAcceptedBy         User?                   @relation("WorkOrderUnitAcceptor", fields: [unitAcceptedById], references: [id])
  unitAcceptanceNote     String?

  // ── Admin acceptance (acceptance form sent to admins) ──
  adminAcceptedAt        DateTime?
  adminAcceptedById      String?
  adminAcceptedBy        User?                   @relation("WorkOrderAdminAcceptor", fields: [adminAcceptedById], references: [id])
  adminAcceptanceNote    String?

  status                 WorkOrderStatus         @default(PENDING_ADMIN)
  deliveryStatus         WorkOrderDeliveryStatus @default(NOT_STARTED)

  // Aggregated qty trackers (kept in sync from invoices).
  deliveredQty           Float                   @default(0)
  invoicedQty            Float                   @default(0)
  invoicedAmount         Float                   @default(0)

  // Set when the unit marks the WO fully delivered. Used for on-time %.
  completedAt            DateTime?

  createdById            String
  createdBy              User                    @relation("WorkOrderCreator", fields: [createdById], references: [id])
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  extensions             WorkOrderExtension[]
  invoices               WorkOrderInvoice[]

  @@index([assignedUnitId])
  @@index([status])
  @@index([pdcDate])
}

// PDC extension log (Extension 1, 2, ...). Latest extension's newPdcDate is the
// effective PDC for on-time computation.
model WorkOrderExtension {
  id           String    @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  extensionNo  Int
  newPdcDate   DateTime
  reason       String?
  grantedAt    DateTime  @default(now())
  grantedById  String?
  grantedBy    User?     @relation("WorkOrderExtensionGranter", fields: [grantedById], references: [id])

  @@unique([workOrderId, extensionNo])
  @@index([workOrderId])
}

// Per-invoice qty + amount log (qty-wise invoice tracking).
model WorkOrderInvoice {
  id           String    @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  invoiceNo    String
  invoiceDate  DateTime
  quantity     Float
  amount       Float?
  remarks      String?
  createdById  String?
  createdBy    User?     @relation("WorkOrderInvoiceCreator", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())

  @@index([workOrderId])
}

enum WorkOrderStatus {
  PENDING_ADMIN     // drafted by SUPPLY_CHAIN; awaiting admin acceptance
  ADMIN_ACCEPTED    // admin accepted; awaiting unit acceptance
  UNIT_ACCEPTED     // unit acknowledged; execution begins
  IN_PROGRESS       // ≥1 invoice logged
  COMPLETED         // delivered qty ≥ order qty
  CLOSED
  CANCELLED
  REJECTED          // admin rejected
  ON_HOLD           // unit rejected; awaiting reassignment by supply chain/admin
}

enum WorkOrderDeliveryStatus {
  NOT_STARTED
  IN_PROGRESS
  PARTIAL
  DELIVERED
  DELAYED
}

// ──── METROLOGY / CALIBRATION ITEMS ────
// One row per piece of equipment that Metrology calibrates. Categorised by
// equipment kind so the UI can route each list to its dedicated page.
// Write access is restricted to METROLOGY + ADMIN; all other procurement-chain
// roles see read-only listings.
model CalibrationItem {
  id                     String              @id @default(uuid())
  category               CalibrationCategory
  mmrSubCategory         MmrSubCategory? // only meaningful when category = MMR
  mirNo                  String?
  mirDate                DateTime?
  name                   String // e.g. "Pressure Gauge", "Vernier Caliper"
  make                   String?
  model                  String?
  serialNo               String?
  rapsplSerialNo         String?
  operatingRange         String? // e.g. "0-400 Kg/Cm²"
  capacityMin            String? // for weighing balances
  capacityMax            String? // for weighing balances
  leastCount             String?
  unitLocation           String? // UNIT-I, UNIT-II, UNIT-III, UNIT-V, UNIT-S, Store, etc.
  usedFor                String? // e.g. "Hydraulic Press-I", "Autoclave"
  calibrationOn          DateTime?
  calibrationDueDate     DateTime?
  recallDueDate          DateTime?
  calibrationCertificate String?
  periodicity            String              @default("Every One Year")
  notes                  String?
  remarks                String?
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  records                CalibrationRecord[]

  @@index([category])
  @@index([mmrSubCategory])
  @@index([unitLocation])
}

// Per-fiscal-year calibration history rows shown side-by-side in the register
// (FY 26-27, FY 27-28, …). Each holds the QC verifier, calibration dates,
// certificate number and optional uploaded certificate PDF for that year.
model CalibrationRecord {
  id                    String          @id @default(uuid())
  itemId                String
  item                  CalibrationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fiscalYear            String // "FY 26-27"
  qcVerifiedBy          String?
  verifiedOn            DateTime?
  certificateNo         String?
  certificateAttachment String? // public URL to uploaded PDF
  calibratedOn          DateTime?
  dueDate               DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([itemId, fiscalYear])
  @@index([itemId])
}

enum CalibrationCategory {
  PRESSURE_GAUGE
  VACUUM_GAUGE
  WEIGHING_BALANCE
  TESTING_EQUIPMENT
  METROLOGY_INSTRUMENT
  MMR // Monitoring & Measuring Resources — thermocouples / temperature controllers
}

// Sub-category buckets used when filtering Monitoring & Measuring Resources
// from the universal MMR search.
enum MmrSubCategory {
  PRESSURE_GAUGES
  VACUUM_GAUGES
  METROLOGY_INSTRUMENTS
  LAB_TESTING_EQUIPMENT
  AUTOCLAVE_OVEN_THERMOCOUPLES
  EOT_CRANES_CHAIN_BLOCKS
  OTHER
}

// ──── NOTIFICATIONS ────
model Notification {
  id           String   @id @default(uuid())
  type         String
  title        String
  message      String
  productId    String?
  targetRole   String?
  targetUserId String?
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])
  sentById     String?
  sentBy       User?    @relation("SentBy", fields: [sentById], references: [id])
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}
