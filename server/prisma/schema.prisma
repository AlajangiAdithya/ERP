generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──── USERS & AUTH ────
model User {
  id                         String                           @id @default(uuid())
  username                   String                           @unique
  passwordHash               String
  plainPassword              String?
  name                       String
  role                       Role                             @default(MANAGER)
  unitId                     String?
  unit                       Unit?                            @relation(fields: [unitId], references: [id])
  isActive                   Boolean                          @default(true)
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt
  sessions                   Session[]
  auditLogs                  AuditLog[]
  productRequests            ProductRequest[]
  sentNotifications          Notification[]                   @relation("SentBy")
  pushSubscriptions          PushSubscription[]
  purchaseRequests           PurchaseRequest[]                @relation("PurchaseRequestManager")
  purchaseRequestApprovals   PurchaseRequest[]                @relation("PurchaseRequestApprover")
  purchaseRequestQcApprovals PurchaseRequest[]                @relation("PurchaseRequestQcApprover")
  // New relations for procurement workflow
  targetedNotifications      Notification[]                   @relation("TargetUser")
  quotationsCreated          Quotation[]                      @relation("QuotationCreator")
  quotationsSubmittedToAdmin Quotation[]                      @relation("QuotationSubmitter")
  purchaseOrdersCreated      PurchaseOrder[]                  @relation("POCreator")
  purchaseOrdersCreditPlaced PurchaseOrder[]                  @relation("POCreditPlacer")
  purchaseOrdersClosed       PurchaseOrder[]                  @relation("POCloser")
  paymentRequestsCreated     PaymentRequest[]                 @relation("PaymentCreator")
  paymentRequestsProcessed   PaymentRequest[]                 @relation("PaymentProcessor")
  qcInspections              QCInspection[]                   @relation("QCInspector")
  qcInspectionRequests       QCInspection[]                   @relation("QCInspectionRequestor")
  gatePassesCreated          GatePass[]                       @relation("GatePassCreator")
  gatePassesSiteApproved     GatePass[]                       @relation("GatePassSiteIncharge")
  gatePassesStoreApproved    GatePass[]                       @relation("GatePassStoreIncharge")
  gatePassesAccountsApproved GatePass[]                       @relation("GatePassAccountsApprover")
  gatePassesFinalApproved    GatePass[]                       @relation("GatePassFinalApprover")
  gatePassesCollected        GatePass[]                       @relation("GatePassCollector")
  fimBatchesAssigned         ProductBatch[]                   @relation("FimAssignedBy")
  fimBatchesAccepted         ProductBatch[]                   @relation("FimAcceptedBy")
  fimBatchesReadyToSendOut   ProductBatch[]                   @relation("FimReadyToSendOutBy")
  ionsCreated                InterOfficeNote[]                @relation("IONCreator")
  ionsAssigned               InterOfficeNote[]                @relation("IONAssignee")
  transferRequestsCreated    InventoryTransferRequest[]       @relation("TransferRequester")
  transferRequestsApproved   InventoryTransferRequest[]       @relation("TransferApprover")
  workOrdersCreated          WorkOrder[]                      @relation("WorkOrderCreator")
  workOrdersAdminAccepted    WorkOrder[]                      @relation("WorkOrderAdminAcceptor")
  workOrdersUnitAccepted     WorkOrder[]                      @relation("WorkOrderUnitAcceptor")
  workOrdersDeliveryUpdated  WorkOrder[]                      @relation("WorkOrderDeliveryUpdater")
  workOrderExtensionsGranted WorkOrderExtension[]             @relation("WorkOrderExtensionGranter")
  workOrderInvoicesLogged    WorkOrderInvoice[]               @relation("WorkOrderInvoiceCreator")
  // ── Work Order Closure flow (per delivery batch) ──
  woClosuresOpened           WorkOrderClosure[]               @relation("WOClosureOpener")
  woClosuresUnitSubmitted    WorkOrderClosure[]               @relation("WOClosureUnitSubmitter")
  woClosuresQCVerified       WorkOrderClosure[]               @relation("WOClosureQCVerifier")
  woClosuresMgmtApproved     WorkOrderClosure[]               @relation("WOClosureMgmtApprover")
  woClosuresInvoiceSent      WorkOrderClosure[]               @relation("WOClosureInvoiceSender")
  woClosuresDeliveryAcked    WorkOrderClosure[]               @relation("WOClosureDeliveryAcker")
  woClosuresPaymentLogged    WorkOrderClosure[]               @relation("WOClosurePaymentLogger")
  woClosureDocsUploaded      WorkOrderClosureDoc[]            @relation("WOClosureDocUploader")
  woHoldsRaised              WorkOrderHoldRequest[]           @relation("WOHoldRaiser")
  woHoldsResolved            WorkOrderHoldRequest[]           @relation("WOHoldResolver")
  woBgEntriesAdded           WorkOrderBgEntry[]               @relation("WOBgEntryAdder")
  woInsuranceEntriesAdded    WorkOrderInsuranceEntry[]        @relation("WOInsuranceEntryAdder")
  woPdcAlertsAcknowledged    WorkOrder[]                      @relation("WorkOrderPdcAlertAcker")
  woPdcAlertsMgrAcknowledged WorkOrder[]                      @relation("WorkOrderPdcAlertMgrAcker")
  woClosuresDcSent           WorkOrderClosure[]               @relation("WOClosureDcSender")
  woClosureWeeklyFollowups   WorkOrderClosureWeeklyFollowup[] @relation("WOClosureWeeklyFollowupContact")
  woAlarmsAcknowledged       WorkOrderAlarm[]                 @relation("WOAlarmAcker")
  woAlarmsResolved           WorkOrderAlarm[]                 @relation("WOAlarmResolver")
  woAlarmNotes               WorkOrderAlarmNote[]             @relation("WOAlarmNoteAuthor")
  materialPoolsCreated       MaterialPool[]                   @relation("MaterialPoolCreator")

  // ── Gate Pass v2 (Local Job / Outside) relations ──
  vehiclesCreated         Vehicle[]  @relation("VehicleCreator")
  gatePassesRequested     GatePass[] @relation("GatePassRequestedBy")
  gatePassesLogistics     GatePass[] @relation("GatePassLogistics")
  gatePassesSiteOfficeAck GatePass[] @relation("GatePassSiteOfficeAck")
  gatePassesLocalReturned GatePass[] @relation("GatePassLocalReturnedBy")

  // ── Driver register + Vehicle trips (multi-gatepass dispatches + ad-hoc) ──
  driversCreated         Driver[]      @relation("DriverCreator")
  vehicleTripsCreated    VehicleTrip[] @relation("VehicleTripCreator")
  vehicleTripsDispatched VehicleTrip[] @relation("VehicleTripDispatcher")
  vehicleTripsReturned   VehicleTrip[] @relation("VehicleTripReturner")

  // ── Machinery + Fire Extinguisher register (Safety dept owns it; Unit-5 also edits) ──
  machineryCreated         Machinery[]        @relation("MachineryCreator")
  fireExtinguishersCreated FireExtinguisher[] @relation("FireExtinguisherCreator")

  // HR / Training domain ownership
  employeesCreated         Employee[]         @relation("EmployeeCreator")
  employeeProfile          Employee?          @relation("EmployeeAccount")
  trainingPlansCreated     TrainingPlan[]     @relation("TrainingPlanCreator")
  trainingPlanItemsCreated TrainingPlanItem[] @relation("TrainingPlanItemCreator")
  trainingSessionsCreated  TrainingSession[]  @relation("TrainingSessionCreator")

  // Attendance register (managers maintain per-unit workforce + daily IN/OUT)
  attendanceEmployeesCreated AttendanceEmployee[]        @relation("AttEmpCreator")
  attendanceMonthSubmissions AttendanceMonthSubmission[] @relation("AttMonthSubmitter")

  // KPI-QMS certifications + QMS documents (Unit-5 uploads; everyone views)
  qmsCertificationsUploaded QmsCertification[] @relation("QmsCertUploader")
  qmsDocumentsUploaded      QmsDocument[]      @relation("QmsDocUploader")

  // Team Chat — primary in-house messaging channel (dashboard).
  messagesSent     Message[] @relation("MessageSender")
  messagesReceived Message[] @relation("MessageRecipient")

  // Personal calendar — private per-user events/reminders.
  calendarEvents CalendarEvent[] @relation("CalendarOwner")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  STORE_MANAGER
  PURCHASE_OFFICER
  ACCOUNTING
  QC
  LAB
  METROLOGY
  NDT
  RND
  SAFETY
  SUPPLY_CHAIN
  DESIGNS
  FINANCE
  PLANNING
  LOGISTICS
  // Human Resources — owns Employees, Skill Matrix, Annual Training Plan and
  // Training Session records. Managers can also append training items for
  // their team into the active Annual Training Plan.
  HR
  // Receives OUTSIDE gate passes at the destination site (e.g., Hyderabad office).
  // Acknowledges arrival with reached-date; this closes the gate pass.
  SITE_OFFICE
  // Hidden owner-only role — never appears in UI lists, dashboards, notification
  // broadcasts, approval chains. Has Real-time Corrections + Backups + Audit pages.
  SUPERADMIN
}

// ──── UNITS ────
model Unit {
  id                         String                      @id @default(uuid())
  name                       String                      @unique
  code                       String                      @unique
  isActive                   Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  users                      User[]
  productRequests            ProductRequest[]
  purchaseRequests           PurchaseRequest[]
  transfersFrom              InventoryTransferRequest[]  @relation("TransferFromUnit")
  transfersTo                InventoryTransferRequest[]  @relation("TransferToUnit")
  productStocks              ProductUnitStock[]
  workOrders                 WorkOrder[]                 @relation("WorkOrderAssignedUnit")
  inwardGatePasses           GatePass[]                  @relation("GatePassDestinationUnit")
  fimBatchesAssigned         ProductBatch[]              @relation("FimAssignedToUnit")
  trainingPlanItems          TrainingPlanItem[]          @relation("TrainingPlanItemUnit")
  attendanceEmployees        AttendanceEmployee[]
  attendanceMonthSubmissions AttendanceMonthSubmission[]
}

// ──── AUDIT LOG ────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ──── PRODUCTS / INVENTORY ────
model Product {
  id                   String                     @id @default(uuid())
  name                 String
  sku                  String                     @unique
  // Customer/legacy identification number from the Material Details register
  // (e.g. 1000, 1001, 1501…). Independent of the auto-generated SKU.
  materialCode         String?                    @unique
  description          String?
  category             String?
  unit                 String                     @default("pcs")
  currentStock         Float                      @default(0)
  minStockLevel        Float                      @default(0)
  // Storage handling — filled by Stores at inward, editable anytime from the
  // products list. Free text (e.g. "12 months", "2-8°C / dry"). MSDS = Material
  // Safety Data Sheet (uploaded PDF).
  shelfLife            String?
  storageTemp          String?
  msdsUrl              String?
  msdsName             String?
  isActive             Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  stockMovements       StockMovement[]
  requestItems         RequestItem[]
  purchaseRequestItems PurchaseRequestItem[]
  batches              ProductBatch[]
  transfers            InventoryTransferRequest[]
  quotationItems       QuotationItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  unitStocks           ProductUnitStock[]
  deptStocks           ProductDeptStock[]
  materialPools        MaterialPool[]
}

// ──── PER-UNIT INVENTORY (Phase 6) ────
// When a PR is created for a unit and inward is done, product quantity is
// indented to that owning unit. Other units must use InventoryTransferRequest
// to move stock between units.
model ProductUnitStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id])
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([productId, unitId])
  @@index([unitId])
}

// ──── PER-DEPARTMENT INVENTORY ────
// Counterpart to ProductUnitStock for non-unit owners. When a PR raised by a
// non-unit department (QC, Designs, Safety, Lab, Metrology, NDT, Planning) is
// inwarded, the quantity is reserved to that department here. Reserved dept stock
// is excluded from the "unassigned pool", so no other role can issue it via a MIV —
// they must raise an InventoryTransferRequest to the owning department to get it.
// Stores is intentionally NOT an owner: Stores-raised stock stays the shared pool.
model ProductDeptStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  dept      String // canonical label: QC / Designs / Safety / Lab / Metrology / NDT / Planning
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([productId, dept])
  @@index([dept])
}

// ──── PRODUCT BATCHES (FIFO lot tracking) ────
model ProductBatch {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchNo       String?
  receivedDate  DateTime @default(now())
  quantity      Float // original inward qty
  remaining     Float // qty still in stock
  unitCost      Float?
  referenceType String? // InwardEntry, PurchaseOrder, InwardEntryNewProduct, InwardGatePass
  referenceId   String?
  notes         String?
  createdById   String?
  createdAt     DateTime @default(now())

  // Direct / cash-purchase inward (Stores → Direct Entry). Supplier is free
  // text because cash purchases often come from unregistered local vendors —
  // surfaced in the product's supplier history alongside PO purchases.
  supplierName        String?
  supplierContact     String?
  supplierAddress     String?
  // Non-unit department this purchase was made for (Safety, QC, Designs …).
  // Unit assignments go through StockMovement.unitId + ProductUnitStock instead.
  assignedDept        String?
  // Mfg / expiry entered by Stores on direct entries. PO-flow batches read
  // these from the linked QC inspection instead.
  dateOfManufacturing DateTime?
  dateOfExpiry        DateTime?

  // FIM (Free Issue Material — customer's property) linkage.
  // Set when this batch was inwarded via an INWARD gate pass.
  isFim                      Boolean       @default(false)
  sourceInwardGatePassId     String?
  sourceInwardGatePass       GatePass?     @relation("FimSourceGatePass", fields: [sourceInwardGatePassId], references: [id])
  sourceInwardGatePassItemId String?
  sourceInwardGatePassItem   GatePassItem? @relation("FimSourceItem", fields: [sourceInwardGatePassItemId], references: [id])

  // FIM unit-assignment + one-shot acceptance (no MIV needed for FIM).
  // Stores assigns a FIM batch to a unit; the unit manager clicks Accept + remark; final.
  assignedToUnitId    String?
  assignedToUnit      Unit?     @relation("FimAssignedToUnit", fields: [assignedToUnitId], references: [id])
  assignedAt          DateTime?
  assignedById        String?
  assignedBy          User?     @relation("FimAssignedBy", fields: [assignedById], references: [id])
  unitAcceptedAt      DateTime?
  unitAcceptedById    String?
  unitAcceptedBy      User?     @relation("FimAcceptedBy", fields: [unitAcceptedById], references: [id])
  unitAcceptedRemarks String?

  // Two-step return: unit manager marks the FIM ready to send back to the customer,
  // then Stores actually creates the outward gate pass. Stores cannot send out
  // until readyToSendOutAt is set.
  readyToSendOutAt   DateTime?
  readyToSendOutById String?
  readyToSendOutBy   User?     @relation("FimReadyToSendOutBy", fields: [readyToSendOutById], references: [id])
  readyToSendOutNote String?

  // PO-flow lot linkage: which QC inspection (lot) this batch came from.
  // Lets the product list show PR → PO → Lot N (invoice) → Batch chain.
  sourceQcInspectionId String?
  sourceQcInspection   QCInspection? @relation("BatchSourceInspection", fields: [sourceQcInspectionId], references: [id])

  @@index([productId, receivedDate])
  @@index([productId, remaining])
  @@index([sourceInwardGatePassItemId])
  @@index([sourceQcInspectionId])
}

// ──── STOCK MOVEMENTS ────
model StockMovement {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  type          MovementType
  quantity      Float
  referenceType String?
  referenceId   String?
  batchNumber   String?
  notes         String?
  performedBy   String?
  unitId        String?
  createdAt     DateTime     @default(now())
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

// ──── PRODUCT REQUESTS / MIV (Requester → Store Manager workflow) ────
// Form No: RAPS/MIV/REV01 Dt: 01/02/2025
model ProductRequest {
  id             String        @id @default(uuid())
  requestNumber  String        @unique
  referenceNo    String? // Reference No. & Date (from MIV form)
  mirNo          String? // MIR NO. (from MIV form)
  issueNo        String? // Issue No.
  issueDate      DateTime? // Issue Date
  managerId      String?
  manager        User?         @relation(fields: [managerId], references: [id], onDelete: SetNull)
  // Null for global requester roles (QC, LAB, SAFETY, DESIGNS …) who draw from
  // the unassigned pool rather than a unit's bucket.
  unitId         String?
  unit           Unit?         @relation(fields: [unitId], references: [id])
  status         RequestStatus @default(PENDING)
  notes          String?
  remarks        String? // Remarks field from MIV form
  clearanceNotes String?
  clearedById    String?
  clearedAt      DateTime?
  collectedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  items          RequestItem[]
}

model RequestItem {
  id              String         @id @default(uuid())
  requestId       String
  request         ProductRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Float
  approvedQty     Float?
  collectedQty    Float          @default(0) // cumulative qty actually taken (partial collection)
  purpose         String? // Purpose (Production fills)
  qtyIssued       Float? // Qty Issue (Store fills)
  materialBatchNo String? // Material Batch No. If any (Store fills)
}

enum RequestStatus {
  PENDING
  APPROVED
  PARTIAL
  REJECTED
  COLLECTED
  CANCELLED
}

// ──── PURCHASE REQUESTS (Requester → Admin → PO → Quotation → Order workflow) ────
model PurchaseRequest {
  id                   String                @id @default(uuid())
  requestNumber        String                @unique
  requestId            String? // Legacy order-name column (kept for backward compat; new PRs leave this null and use requestNumber as the identifier)
  managerId            String?
  manager              User?                 @relation("PurchaseRequestManager", fields: [managerId], references: [id], onDelete: SetNull)
  // Null for global requester roles (STORE_MANAGER, DESIGNS, PLANNING, QC,
  // LAB, METROLOGY, NDT, SAFETY) — they raise PRs in their own name.
  unitId               String?
  unit                 Unit?                 @relation(fields: [unitId], references: [id])
  status               PurchaseRequestStatus @default(PENDING_ADMIN)
  notes                String?
  materialSpecsPdfUrl  String? // Optional material specs PDF attached at PR creation
  // QC-department gate: PRs raised by LAB / METROLOGY / NDT pass through QC
  // before reaching ADMIN. These columns are null for PRs that bypass the QC
  // gate (e.g. raised by MANAGER, DESIGNS, RND, PLANNING, STORE_MANAGER, QC).
  qcNotes              String?
  qcApprovedById       String?
  qcApprovedBy         User?                 @relation("PurchaseRequestQcApprover", fields: [qcApprovedById], references: [id])
  qcApprovedAt         DateTime?
  adminNotes           String?
  adminApprovedById    String?
  adminApprovedBy      User?                 @relation("PurchaseRequestApprover", fields: [adminApprovedById], references: [id])
  adminApprovedAt      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  items                PurchaseRequestItem[]
  quotations           Quotation[]
  purchaseOrders       PurchaseOrder[]
  quotationSources     QuotationSource[]
  purchaseOrderSources PurchaseOrderSource[]
}

// Form No: RAPS/PRF Rev no. 02 Date: 31/08/2024
model PurchaseRequestItem {
  id                     String                        @id @default(uuid())
  requestId              String
  request                PurchaseRequest               @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productId              String?
  product                Product?                      @relation(fields: [productId], references: [id])
  productName            String // Material Description
  productUnit            String                        @default("pcs") // UOM
  requestedQty           Float // Required Quantity
  adminApprovedQty       Float?
  purchasedQty           Float                         @default(0)
  itemStatus             ItemOrderStatus? // Set once ORDER_PLACED; mirrored from PO items
  itemQuotationStatus    PRItemQuotationStatus         @default(AWAITING_QUOTATION) // Per-item quote progress, independent of order/inward status
  // PRF form fields
  materialType           String? // Raw material / Consumable / Hand Tools & Fastners / Tools & Fixtures / Others
  materialSpecification  String? // Material specification data
  // Optional confidential material-spec PDF attached at PR creation time.
  // Shown as a "View spec" link in PR views; merged after the PR body in the
  // downloaded PR PDF; surfaced to QC alongside the source PR.
  specAttachmentUrl      String?
  specAttachmentName     String?
  qapNo                  String? // QAP no. & QAP attachment reference
  drawingNo              String? // Drawing no. & detailed drawing reference
  materialRequiredFor    String? // SO no. / R&D
  internalWorkOrder      String? // Internal Work Order (free text)
  purpose                String? // Purpose
  sourceOfSupply         String? // Source of supply if any
  scopeOfWork            String? // Reports Required / Scope of Work
  inspectionType         String? // Inhouse / External (RAPS QC/Customer QC)
  requiredByDate         DateTime? // Required by date
  itemRemarks            String? // Other details/Remarks
  poItemAllocations      PurchaseOrderItemAllocation[]
  materialPoolMembership MaterialPoolItem?
}

enum PurchaseRequestStatus {
  // PRs from LAB / METROLOGY / NDT start here so QC can approve before ADMIN.
  PENDING_QC
  PENDING_ADMIN
  APPROVED
  QUOTATION_SUBMITTED
  QUOTATION_APPROVED
  ORDER_PLACED
  GOODS_ARRIVED
  QC_PASSED
  INWARD_DONE
  COMPLETED
  REJECTED
  IN_PROGRESS
}

// Per-PR-item quotation progress. Independent of `itemStatus` (which mirrors
// downstream PO/inward state). Lets the UI render fine-grained badges like
// "Quotation not sent yet" for items still missing supplier quotes while
// other items on the same PR have already moved into POs.
enum PRItemQuotationStatus {
  AWAITING_QUOTATION
  QUOTATION_SUBMITTED
  QUOTATION_HELD
  QUOTATION_APPROVED
  CANCELLED
}

// ──── SUPPLIERS (normalised supplier directory) ────
// Quotation/PO rows still snapshot supplierName/Contact/Address so historical
// records survive supplier renames. The supplierId FK is for lookups + history.
model Supplier {
  id                         String                          @id @default(uuid())
  // Vendor ID auto-generated as RAPS/SUP/<NNNN>. Sequential across all FY.
  vendorIdNo                 String?                         @unique
  name                       String                          @unique
  // Legacy single-line contact retained; new format splits into person + phone.
  contact                    String?
  contactPerson              String?
  contactPhone               String?
  address                    String?
  gstNumber                  String?
  email                      String?
  isActive                   Boolean                         @default(true)
  notes                      String?
  // Approved Supplier List columns (client format).
  scopeOfSupply              String?
  materialType               SupplierMaterialType?
  approvalStatus             SupplierApprovalStatus?
  approvalDate               DateTime?
  typeAndExtentOfControl     String?
  remarks                    String?
  // Vendor Evaluation PDF — uploaded once when the supplier is first onboarded.
  // Survives FY data resets; never re-required.
  vendorEvaluationPdfUrl     String?
  vendorEvaluationUploadedAt DateTime?
  // Supplier Assessment PDF — valid only for the financial year stored in
  // `assessmentFiscalYear`. After FY rollover, a new assessment must be uploaded
  // before the supplier can be used on a new quotation.
  supplierAssessmentPdfUrl   String?
  assessmentFiscalYear       String?
  assessmentUploadedAt       DateTime?
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt
  quotations                 Quotation[]
  quotationItems             QuotationItem[]
  purchaseOrders             PurchaseOrder[]
  purchaseOrderItems         PurchaseOrderItem[]
  reEvaluations              SupplierReEvaluation[]
  assessmentForms            SupplierAssessmentForm[]
  performanceRatings         SupplierPerformanceRatingItem[]
}

enum SupplierMaterialType {
  MATERIAL
  JOB_WORK
  SERVICE
}

enum SupplierApprovalStatus {
  APPROVED
  CONDITIONAL
  REJECTED
  TERMINATED
}

// ──── SUPPLIER RE-EVALUATION (one row per review event) ────
// Drives the "Evaluation Details" panel in the Approved Supplier List.
// Snapshot of the printable Supplier Re-Evaluation Form. The latest record per
// (supplier, financialYear) is what the master list shows.
model SupplierReEvaluation {
  id                        String                 @id @default(uuid())
  supplierId                String
  supplier                  Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  financialYear             String // e.g. "26-27"
  initialEvaluationDate     DateTime?
  initialEvaluationScope    String? // Product / Process / Service text
  // YES/NO criteria — nullable boolean so "not answered" is distinct from NO.
  noOrders6Months           Boolean?
  noOrdersReason            String?
  managementChanged         Boolean?
  newMgmtContinuingTerms    Boolean?
  shiftedLocation           Boolean?
  newAddress                String?
  performanceBelowPar       Boolean?
  correctiveActionInitiated String? // free-text: instructions given
  recommendedTermination    Boolean?
  correctiveActionEffective Boolean?
  noNonconformitiesReported Boolean?
  newMachinesAdded          Boolean?
  wishToContinueForNewParts Boolean?
  isoCertified              Boolean?
  // Outcome.
  overallDecision           SupplierReEvalDecision @default(CONTINUES)
  // Schedule.
  evaluationDate            DateTime?
  nextReviewDate            DateTime?
  // Performance score copied from the latest performance rating, or entered
  // manually. Shown in the "Performance Rating after review" column.
  performanceRating         Float?
  remarks                   String?
  evaluatedByUserId         String?
  evaluatedByName           String? // snapshot in case the user is renamed
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([supplierId])
  @@index([supplierId, financialYear])
}

enum SupplierReEvalDecision {
  CONTINUES
  TERMINATED
}

// ──── STRUCTURED VENDOR / SUPPLIER ASSESSMENT FORM ────
// Captured during onboarding (or re-captured if vendor profile changes). The
// existing supplierAssessmentPdfUrl is kept as an optional fallback / scan.
model SupplierAssessmentForm {
  id                        String                @id @default(uuid())
  supplierId                String
  supplier                  Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  financialYear             String // FY the form was submitted under
  companyName               String?
  companyAddress            String?
  businessType              SupplierBusinessType?
  businessRole              SupplierBusinessRole?
  productsRange             String?
  machineryAndEquipment     String?
  majorCustomers            String?
  transportFacilities       String?
  deliveryPeriod            String?
  allowsCapabilityVerify    Boolean?
  hasQualityControlSystem   Boolean?
  isoCertified              Boolean?
  isoCertificateUrl         String?
  testCertWithDelivery      Boolean?
  readyToUpgradePerformance Boolean?
  reviewComments            String?
  reviewedByName            String?
  reviewedByUserId          String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  @@index([supplierId])
  @@index([supplierId, financialYear])
}

enum SupplierBusinessType {
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LTD
  PUBLIC_LTD
}

enum SupplierBusinessRole {
  MANUFACTURER
  SUPPLIER
  DEALER
}

// ──── SUPPLIER PERFORMANCE RATING (FY-bucketed scorecard) ────
// Header carries the period and overall summary; one row per (item, supplier)
// in items. Mirrors the printable rating sheet — the overall % is recomputed
// from item rows on every write.
model SupplierPerformanceRating {
  id               String                          @id @default(uuid())
  financialYear    String // e.g. "24-25"
  periodFrom       DateTime?
  periodTo         DateTime?
  preparedDate     DateTime?
  preparedByName   String?
  preparedByUserId String?
  minimumCriteria  Float                           @default(85)
  overallRating    Float? // computed from items
  remarks          String?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  items            SupplierPerformanceRatingItem[]

  @@unique([financialYear])
  @@index([financialYear])
}

model SupplierPerformanceRatingItem {
  id               String                    @id @default(uuid())
  ratingId         String
  rating           SupplierPerformanceRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)
  supplierId       String?
  supplier         Supplier?                 @relation(fields: [supplierId], references: [id])
  itemDescription  String
  supplierName     String
  suppliesReceived Int                       @default(0)
  qtyAccepted      Int                       @default(0)
  qualityRating    Float                     @default(0) // out of 60
  totalDeliveries  Int                       @default(0)
  deliveriesOnTime Int                       @default(0)
  deliveriesLate   Int                       @default(0)
  deliveryRating   Float                     @default(0) // out of 40
  totalRating      Float                     @default(0) // out of 100
  createdAt        DateTime                  @default(now())

  @@index([ratingId])
  @@index([supplierId])
}

// ──── MATERIAL POOLS (PO bundles same-material lines across PRs before quoting) ────
// A pool groups ≥2 PurchaseRequestItems that share a material so the PO can
// collect competing quotes covering all of them at once. Pool membership is
// orthogonal to itemQuotationStatus — a pooled item stays AWAITING_QUOTATION
// until a union quotation tied to the pool gets submitted. When that quote is
// approved, the pool flips to APPROVED and the underlying PR-items follow the
// union PO's allocation chain (PurchaseOrderItemAllocation) for FIFO inward.
model MaterialPool {
  id          String             @id @default(uuid())
  productId   String?
  product     Product?           @relation(fields: [productId], references: [id])
  productName String
  productUnit String             @default("pcs")
  status      MaterialPoolStatus @default(OPEN)
  createdById String
  createdBy   User               @relation("MaterialPoolCreator", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       MaterialPoolItem[]

  @@index([status])
  @@index([productId])
}

model MaterialPoolItem {
  id                    String              @id @default(uuid())
  poolId                String
  pool                  MaterialPool        @relation(fields: [poolId], references: [id], onDelete: Cascade)
  purchaseRequestItemId String              @unique
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id], onDelete: Cascade)
  pooledAt              DateTime            @default(now())

  @@index([poolId])
}

enum MaterialPoolStatus {
  OPEN // accepting union quotations
  QUOTED // ≥1 union quotation submitted to admin
  APPROVED // one union quotation approved → PO live
  CANCELLED // pool dissolved
}

// ──── QUOTATIONS (PO collects from suppliers) ────
model Quotation {
  id                      String            @id @default(uuid())
  quotationNumber         String            @unique
  purchaseRequestId       String?
  purchaseRequest         PurchaseRequest?  @relation(fields: [purchaseRequestId], references: [id])
  isUnion                 Boolean           @default(false)
  supplierId              String?
  supplier                Supplier?         @relation(fields: [supplierId], references: [id])
  supplierName            String?
  supplierContact         String?
  supplierAddress         String?
  totalAmount             Float
  notes                   String?
  quotationPdfUrl         String? // Optional supplier-quote PDF uploaded by PO
  selectionNote           String? // Admin's note explaining why this quote was chosen
  isSelected              Boolean           @default(false)
  holdNote                String? // Admin's reason for putting the quotation on hold (compliance docs missing, etc.)
  heldAt                  DateTime? // Timestamp when admin put this quotation on hold
  // PO must explicitly send the batch to admin before admin can see/approve it.
  // Null = still in PO draft; non-null = visible to admin for review.
  submittedToAdminAt      DateTime?
  submittedToAdminById    String?
  submittedToAdmin        User?             @relation("QuotationSubmitter", fields: [submittedToAdminById], references: [id])
  // Set when admin approves a competing quote on the same coverage — soft-archives
  // this quote so it disappears from the queue but stays for supplier-price history.
  supersededAt            DateTime?
  supersededByQuotationId String?
  supersededBy            Quotation?        @relation("QuotationSuperseded", fields: [supersededByQuotationId], references: [id])
  superseded              Quotation[]       @relation("QuotationSuperseded")
  createdById             String
  createdBy               User              @relation("QuotationCreator", fields: [createdById], references: [id])
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  items                   QuotationItem[]
  purchaseOrders          PurchaseOrder[]
  sourceRequests          QuotationSource[]
}

// Junction: links a union Quotation to its source PurchaseRequests
model QuotationSource {
  id                String          @id @default(uuid())
  quotationId       String
  quotation         Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([quotationId, purchaseRequestId])
}

model QuotationItem {
  id                String    @id @default(uuid())
  quotationId       String
  quotation         Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?  @relation(fields: [productId], references: [id])
  productName       String
  productUnit       String    @default("pcs")
  quantity          Float
  unitPrice         Float
  totalPrice        Float
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  supplierName      String
  supplierContact   String?
  supplierAddress   String?
  // Per-product supplier-quote PDF uploaded by PO. One quote document per item,
  // independent of the quotation-level quotationPdfUrl (kept for older rows /
  // single combined quotes).
  quotationPdfUrl   String?
  // For union quotations: per-PR-item allocation breakdown captured at quotation creation
  // so it can be carried into PurchaseOrderItemAllocation when the quotation is approved.
  // Shape: [{ purchaseRequestItemId: string, allocatedQty: number }]
  sourceAllocations Json?
}

// ──── PURCHASE ORDERS (created when quotation is selected) ────
model PurchaseOrder {
  id                String                @id @default(uuid())
  orderNumber       String                @unique
  customName        String
  purchaseRequestId String?
  purchaseRequest   PurchaseRequest?      @relation(fields: [purchaseRequestId], references: [id])
  isUnion           Boolean               @default(false)
  quotationId       String
  quotation         Quotation             @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  supplierId        String?
  supplier          Supplier?             @relation(fields: [supplierId], references: [id])
  supplierName      String
  totalAmount       Float
  advancePaid       Float                 @default(0)
  totalPaid         Float                 @default(0)
  goodsArrived      Boolean               @default(false)
  goodsArrivedAt    DateTime?
  delayNote         String? // Optional note when PO placed ≥3 days after PR creation
  mirNo             String? // Auto-generated at stores inward (MIR-YYYYMMDD-NNN)
  inwardedAt        DateTime? // Timestamp of stores inward
  // Signed PO PDF uploaded by Purchase Officer after the quotation is approved.
  // This is the single source of truth for the PO document — no auto-generated PDF is offered.
  poDocumentUrl     String?
  status            PurchaseOrderStatus   @default(PENDING_ACCOUNTING)
  // Credit-based order placement: PO Officer can place order on word-of-trust
  // before payment is processed. Order proceeds, payment follows later.
  isCreditOrder     Boolean               @default(false)
  creditPlacedAt    DateTime?
  creditPlacedById  String?
  creditPlacedBy    User?                 @relation("POCreditPlacer", fields: [creditPlacedById], references: [id])
  creditNote        String?
  // Manual close — Purchase Officer clicks "Close PO" once everything is received & paid.
  // Force-close is allowed with `forceClosed=true` when some qty is still pending or payment is short;
  // in that case leftover PR items are cancelled.
  closedAt          DateTime?
  closedById        String?
  closedBy          User?                 @relation("POCloser", fields: [closedById], references: [id])
  closeReason       String?
  forceClosed       Boolean               @default(false)
  createdById       String
  createdBy         User                  @relation("POCreator", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  items             PurchaseOrderItem[]
  paymentRequests   PaymentRequest[]
  qcInspections     QCInspection[]
  sourceRequests    PurchaseOrderSource[]
}

// Junction: links a union PurchaseOrder to its source PurchaseRequests
model PurchaseOrderSource {
  id                String          @id @default(uuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  createdAt         DateTime        @default(now())

  @@unique([purchaseOrderId, purchaseRequestId])
  // Reverse-direction lookups (find POs for a PR).
  @@index([purchaseRequestId])
}

model PurchaseOrderItem {
  id                    String                        @id @default(uuid())
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder                 @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId             String?
  product               Product?                      @relation(fields: [productId], references: [id])
  productName           String
  productUnit           String                        @default("pcs")
  quantity              Float
  unitPrice             Float
  totalPrice            Float
  receivedQty           Float                         @default(0)
  itemStatus            ItemOrderStatus               @default(WAITING)
  purchaseRequestItemId String?
  supplierId            String?
  supplier              Supplier?                     @relation(fields: [supplierId], references: [id])
  statusUpdatedAt       DateTime?
  statusUpdatedBy       String?
  allocations           PurchaseOrderItemAllocation[]
  inspectionItems       QCInspectionItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([purchaseRequestItemId])
  @@index([supplierId])
}

// For union PO items: tracks per-PR-item allocation of the consolidated quantity.
// Non-union items leave this empty and use PurchaseOrderItem.purchaseRequestItemId.
model PurchaseOrderItemAllocation {
  id                    String              @id @default(uuid())
  purchaseOrderItemId   String
  purchaseOrderItem     PurchaseOrderItem   @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  purchaseRequestItemId String
  purchaseRequestItem   PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id])
  allocatedQty          Float
  receivedQty           Float               @default(0)
  createdAt             DateTime            @default(now())

  @@unique([purchaseOrderItemId, purchaseRequestItemId])
  // Composite @@unique above already covers purchaseOrderItemId-leading queries.
  // Index purchaseRequestItemId for joins/lookups in the FIFO allocator.
  @@index([purchaseRequestItemId])
}

enum ItemOrderStatus {
  WAITING
  ORDERED
  ON_THE_WAY
  RECEIVED
  CANCELLED
}

enum PurchaseOrderStatus {
  PENDING_ACCOUNTING
  CREDIT_PLACED
  ORDERED
  PLACED
  ADVANCE_PAID
  PAYMENT_PENDING
  PAID
  GOODS_ARRIVED
  QC_PENDING
  QC_PASSED
  QC_FAILED
  PARTIAL
  INWARD_DONE
  COMPLETED
  CLOSED
}

// ──── PAYMENT REQUESTS (PO → Accounting) ────
model PaymentRequest {
  id              String               @id @default(uuid())
  paymentNumber   String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  amount          Float
  paymentType     PaymentType
  status          PaymentRequestStatus @default(PENDING)
  notes           String?
  processedById   String?
  processedBy     User?                @relation("PaymentProcessor", fields: [processedById], references: [id])
  processedAt     DateTime?
  createdById     String
  createdBy       User                 @relation("PaymentCreator", fields: [createdById], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

// ──── QC INSPECTIONS ────
// Form No: RAPS/IIR Rev 01, Dt: 01/09/2024 (Inward Inspection Request + Report)
model QCInspection {
  id                   String             @id @default(uuid())
  inspectionNumber     String             @unique // ION No.
  // Nullable so stock-statement / opening-balance batches can attach a lightweight
  // QC record carrying batchNo / DOM / DOE / referredUnit without a parent PO.
  purchaseOrderId      String?
  purchaseOrder        PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  result               QCResult           @default(PENDING)
  parameters           Json? // Flexible inspection parameters
  notes                String?
  requestCreatedById   String? // Who created the inspection request (Purchase/Stores)
  requestCreatedBy     User?              @relation("QCInspectionRequestor", fields: [requestCreatedById], references: [id])
  inspectedById        String? // Who filled the inspection report (QC)
  inspectedBy          User?              @relation("QCInspector", fields: [inspectedById], references: [id])
  inspectedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  // ── Page 1: Inward Inspection Request fields ──
  invoiceNo            String? // 11. Invoice no. & date
  invoiceDate          DateTime?
  dcNo                 String? // 12. DC no. if any
  gatePassNo           String? // 13. Gate pass no. (FIM/Others)
  gatePassType         String? // 14. Gate pass type
  probableDateOfReturn DateTime? // 15. Probable date of Return
  materialReceiptDate  DateTime? // 16. Material receipt date @ RAPS Store
  // ── Page 2: Inward Inspection Report fields ──
  reportNo             String? // Inspection report no.
  reportDate           DateTime?
  materialDescription  String? // Material description and specification
  materialCategory     String? // Raw materials / Consumables / Tooling & Fixtures / FIM
  documentTypes        Json? // Checkboxes: Test Report, COC, COA, 3rd Party/Customer Clearance
  // ── Phase 4: PO-driven inspection request + QC re-review flow ──
  docRequirement       String? // COA / COC / ANY_REPORTS chosen at inspection request
  docRequirementNote   String? // Free text note alongside docRequirement
  uploadedDocs         Json? // Array of {filename, url, uploadedById, uploadedAt} from PO
  pendingReason        String? // Reason QC marked Pending; bounces back to PO
  iteration            Int                @default(1) // Increment each re-review cycle
  inspectionLocation   String? // Dimensional Inspection at Supplier Place / at RAPS Inward
  reportReferenceNo    String? // Report reference no.
  packingCondition     String? // Sealed / Broken
  packingDamageNotes   String? // If damages, mention
  batchNo              String? // Batch no./Identification
  dateOfManufacturing  DateTime? // Date of manufacturing
  dateOfExpiry         DateTime? // Date of Expiry
  tappedHolesCondition String? // Check condition of tapped holes, weld lugs
  // Quantity tracking
  qtyAsPerPR           Float? // Quantity as per PR
  qtyOrdered           Float? // Quantity ordered
  qtyReceived          Float? // Quantity Received
  qtyAccepted          Float? // Quantity Accepted
  qtyRejected          Float? // Quantity Rejected
  rejectionReason      String? // Reason for Rejection/Non conformity
  remarks              String? // Remarks
  mirNo                String? // MIR No. (Store to be filled)
  // ── Per-lot delivery tracking ──
  // Lot number scoped per PO: 1st lot = 1, 2nd = 2, ... Set on creation.
  lotNumber            Int?
  // Total qty arrived in this lot (sum of items[].arrivedQty)
  arrivedQty           Float?
  // Invoice PDF uploaded by Purchase Officer for this specific lot
  invoiceFileUrl       String?
  // Lot report PDF (supplier test report / COA / COC / mill cert) uploaded by
  // Purchase Officer alongside the invoice when raising the QC request.
  lotReportFileUrl     String?
  // Per-item arrived qty rows for this lot
  items                QCInspectionItem[]
  // Batches inwarded against this lot (FIFO traceability)
  batches              ProductBatch[]     @relation("BatchSourceInspection")

  @@index([purchaseOrderId])
  @@index([inspectedById])
  @@index([requestCreatedById])
}

// Per-item arrived qty for a specific lot (QCInspection).
// Allows "Lot 1: Item A 400kg, Item B 100kg" attribution.
model QCInspectionItem {
  id                  String            @id @default(uuid())
  inspectionId        String
  inspection          QCInspection      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  arrivedQty          Float
  createdAt           DateTime          @default(now())

  @@index([inspectionId])
  @@index([purchaseOrderItemId])
}

enum QCResult {
  PENDING
  PASSED
  FAILED
  PARTIAL
  ON_HOLD
}

// ──── GATE PASS REQUEST (RAMS/GPR/01) ────
// Workflow: Unit Manager (Site Incharge) → Store Incharge → Accounts → Final Approval
// Approved passes can later be marked RETURNED (returnable items) or CLOSED.
model GatePass {
  id                   String             @id @default(uuid())
  passNumber           String             @unique // Doc/Request No
  // FIM/Customer Property Register number (INWARD STORES only).
  // Format: RAPS/FIM/<FY>/<N>. Distinct from passNumber (RAPS/GP/...) so the
  // FIM register can list entries by their own running count.
  fimNumber            String?            @unique
  // INWARD-only: cross-reference to an internal gate-pass requisition number
  // (the requisitioner's reference for this FIM intake).
  gpRequisitionNo      String?
  passType             GatePassType? // Dominant / legacy type (per-item overrides)
  direction            GatePassDirection  @default(OUTWARD) // INWARD = customer → us, OUTWARD = us → customer/site
  // OUTWARD only. LOCAL_JOB = sent to an external vendor for job-work (returnable / non-returnable);
  // OUTSIDE = sent to one of our other sites (e.g., Hyderabad office). Null for INWARD/legacy rows.
  kind                 GatePassKind?
  // Local Job Work Register (RAPS/JL-JW) header fields.
  jobWorkNo            String? // JW NO / RAPS PO Order No.
  jobWorkDate          DateTime? // Date against the JW / RAPS PO order
  requestedById        String?
  requestedBy          User?              @relation("GatePassRequestedBy", fields: [requestedById], references: [id])
  // Logistics step (both LOCAL_JOB and OUTSIDE).
  assignedVehicleId    String?
  assignedVehicle      Vehicle?           @relation("GatePassVehicle", fields: [assignedVehicleId], references: [id])
  // Driver chosen at dispatch (from Driver register). May be null for legacy rows.
  assignedDriverId     String?
  assignedDriver       Driver?            @relation("GatePassDriver", fields: [assignedDriverId], references: [id])
  // When two or more gatepasses ride in the same vehicle, they share a VehicleTrip.
  tripId               String?
  trip                 VehicleTrip?       @relation("TripGatePasses", fields: [tripId], references: [id])
  logisticsById        String?
  logisticsBy          User?              @relation("GatePassLogistics", fields: [logisticsById], references: [id])
  logisticsAt          DateTime?
  dispatchedAt         DateTime?
  // OUTSIDE only: PDF signed by driver, uploaded by logistics on dispatch.
  signedDeliveryPdfUrl String?
  // OUTSIDE only: Logistics acknowledges arrival at destination after delivery.
  // (Historically these columns were called "siteOfficeAck*" when the SITE_OFFICE
  // role owned this step; now Logistics handles both dispatch and arrival ack.)
  siteOfficeAckById    String?
  siteOfficeAckBy      User?              @relation("GatePassSiteOfficeAck", fields: [siteOfficeAckById], references: [id])
  siteOfficeAckAt      DateTime?
  reachedDate          DateTime?
  // Returnable close — both LOCAL_JOB and OUTSIDE: stores acknowledges return.
  localReturnedAt      DateTime?
  localReturnedById    String?
  localReturnedBy      User?              @relation("GatePassLocalReturnedBy", fields: [localReturnedById], references: [id])
  date                 DateTime           @default(now())
  siteName             String? // Site (header)
  partyName            String? // Auto-derived from items.dispatchedTo (legacy column)
  partyContact         String?
  // INWARD-only: details from the customer's own gate pass document
  customerName         String?
  customerGatePassNo   String? // customer's gate pass number (their format, not RAPS)
  customerGatePassDate DateTime?
  customerContact      String? // Deprecated — no longer collected; kept for legacy rows.
  // INWARD-only: document type of the customer's gate pass (ORIGINAL or DUPLICATE)
  // and an uploaded PDF of the customer's GP document.
  customerGpDocType    CustomerGpDocType?
  customerGpPdfUrl     String?
  // INWARD only: how the material is being inwarded.
  // STORES = goes through the From-Gatepass acceptance into the product list (existing flow).
  // DIRECT_TO_UNIT = sent straight to a unit; that unit's manager marks it Collected on the gatepass itself.
  inwardKind           InwardKind?
  destinationUnitId    String?
  destinationUnit      Unit?              @relation("GatePassDestinationUnit", fields: [destinationUnitId], references: [id])
  collectedAt          DateTime?
  collectedById        String?
  collectedBy          User?              @relation("GatePassCollector", fields: [collectedById], references: [id])
  vehicleNo            String? // Filled by Store Incharge when arranging the vehicle
  driverName           String? // Filled by Store Incharge when arranging the vehicle
  driverPhone          String? // Driver contact — captured for private/hired dispatch
  // Logistics dispatched this gate pass with a one-off hired/private vehicle that
  // isn't in the Vehicle register. vehicleNo/driverName/driverPhone hold the details
  // and assignedVehicleId stays null.
  privateVehicle       Boolean            @default(false)
  invoiceNo            String?
  dcNo                 String?
  purpose              String? // Legacy (now per-item)
  status               GatePassStatus     @default(PENDING_STORE)
  expectedReturnDate   DateTime? // Legacy (now per-item)
  actualReturnDate     DateTime?
  returnedBy           String?
  issuedToName         String?
  issuedToDept         String?
  requisitionNo        String?
  remarks              String?
  rejectedReason       String?

  // Approval trail
  siteInchargeById  String?
  siteInchargeAt    DateTime?
  storeInchargeById String?
  storeInchargeAt   DateTime?
  accountsById      String?
  accountsAt        DateTime?
  approvedById      String?
  approvedAt        DateTime?

  createdById      String
  createdBy        User   @relation("GatePassCreator", fields: [createdById], references: [id])
  siteIncharge     User?  @relation("GatePassSiteIncharge", fields: [siteInchargeById], references: [id])
  storeIncharge    User?  @relation("GatePassStoreIncharge", fields: [storeInchargeById], references: [id])
  accountsApprover User?  @relation("GatePassAccountsApprover", fields: [accountsById], references: [id])
  finalApprover    User?  @relation("GatePassFinalApprover", fields: [approvedById], references: [id])

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     GatePassItem[]

  // FIM linkage: batches that were inwarded from this (INWARD) gate pass
  fimBatches ProductBatch[] @relation("FimSourceGatePass")
}

model GatePassItem {
  id                   String        @id @default(uuid())
  gatePassId           String
  gatePass             GatePass      @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  description          String // Name of components
  quantity             Float         @default(1)
  unit                 String        @default("pcs")
  // Per-row fields matching RAMS/GPR/01
  dispatchedTo         String?
  itemPurpose          String?
  probableReturnDate   DateTime?
  itemPassType         GatePassType?
  gatePassDetails      String?
  transportation       String?
  contactPersonDetails String?
  remarks              String? // Legacy

  // INWARD bookkeeping: how much of this item has been accepted into stores / made into a Product
  inwardedQty Float @default(0)

  // OUTWARD Delivery Challan linkage: if this item is FIM going back to the
  // customer, point to the originating INWARD GatePassItem so the cycle closes.
  sourceInwardGatePassItemId String?
  sourceInwardGatePassItem   GatePassItem?  @relation("InwardOutwardLink", fields: [sourceInwardGatePassItemId], references: [id])
  outwardLinkedItems         GatePassItem[] @relation("InwardOutwardLink")

  // FIM batches created from this INWARD item
  fimBatches ProductBatch[] @relation("FimSourceItem")

  @@index([gatePassId])
  @@index([sourceInwardGatePassItemId])
}

enum GatePassType {
  RETURNABLE
  NON_RETURNABLE
  DELIVERY_CHALLAN
}

enum GatePassDirection {
  INWARD
  OUTWARD
}

enum GatePassKind {
  LOCAL_JOB // sent to an external vendor for job-work; returnable or non-returnable
  OUTSIDE // sent to one of our other sites (Hyderabad office, etc.)
}

enum InwardKind {
  STORES
  DIRECT_TO_UNIT
}

enum CustomerGpDocType {
  ORIGINAL
  DUPLICATE
}

enum GatePassStatus {
  DRAFT
  PENDING_STORE
  PENDING_ACCOUNTS
  PENDING_STORE_REVIEW // OUTWARD v2: stores final review after accounts (OUTSIDE) or after approve (LOCAL_JOB)
  PENDING_LOGISTICS // OUTWARD v2: logistics assigns vehicle (+ uploads signed PDF on dispatch for OUTSIDE)
  IN_TRANSIT // OUTWARD v2: dispatched, awaiting acknowledgement
  PENDING_RETURN // OUTWARD v2 LOCAL_JOB returnable: awaiting stores to ack return
  PENDING_APPROVAL
  PENDING_ACCEPTANCE // INWARD-only: customer's material arrived, awaiting stores to inward into products
  ACCEPTED // INWARD-only: stores has inwarded items into products list
  APPROVED
  RETURNED
  CLOSED
  REJECTED
  // Legacy
  OPEN
}

// ──── INTER OFFICE NOTE (ION) — MANAGER ↔ LAB / METROLOGY / NDT workflows ────
// Standard form: Doc No RAMS/ION/00 (LAB / METROLOGY / cross-unit MANAGER).
// NDT variant:  Doc No RAPS/ION-7 — adds qty + per-activity sub-details (UT/RT/VT).
model InterOfficeNote {
  id                 String    @id @default(uuid())
  ionNumber          String    @unique
  userReferenceNo    String?
  section            String?
  projectName        String?
  supplyOrderNo      String?
  referenceDocQA     String?
  materialSupplyDate DateTime?
  sampleRequired     Boolean   @default(false)
  reportGeneration   Boolean   @default(false)
  requiredByDate     DateTime?
  completedDate      DateTime?
  externalQAWitness  String?
  qcContactDetails   String?
  otherInformation   String?
  reportNoAndDate    String? // NDT only: "Report No & Date" closing field
  status             IONStatus @default(SENT)
  recipientRole      String?   @default("LAB") // LAB | METROLOGY | NDT | RND | DESIGNS (when not assigned to a specific manager)
  createdById        String
  createdBy          User      @relation("IONCreator", fields: [createdById], references: [id])
  assignedToId       String?
  assignedTo         User?     @relation("IONAssignee", fields: [assignedToId], references: [id])
  remarks            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  items              IONItem[]
}

model IONItem {
  id                  String          @id @default(uuid())
  ionId               String
  ion                 InterOfficeNote @relation(fields: [ionId], references: [id], onDelete: Cascade)
  jobIdentification   String
  activityRequired    String?
  materialComposition String?
  drawingNo           String?
  specification       String?
  // NDT extras (RAPS/ION-7). Left nullable so the standard form is unaffected.
  nameOfJob           String?
  qty                 String?
  itemRemarks         String?
  ndtDetails          Json? // { method, gridSize, gridPoints, stage, acceptanceLimit, shotType, shotCount, acceptanceCriteria }
}

enum IONStatus {
  SENT
  WAITING
  COLLECTED
}

// ──── INVENTORY TRANSFER REQUEST (unit-to-unit stock transfers) ────
model InventoryTransferRequest {
  id              String         @id @default(uuid())
  transferNumber  String         @unique
  // An owner is EITHER a unit (unitId) OR a department (dept string) — exactly one
  // per side, enforced in the route. Unit FKs are nullable so dept↔dept / dept↔unit
  // transfers are possible; dept owners use the canonical labels (QC, Designs, …).
  fromUnitId      String?
  fromUnit        Unit?          @relation("TransferFromUnit", fields: [fromUnitId], references: [id])
  fromDept        String?
  toUnitId        String?
  toUnit          Unit?          @relation("TransferToUnit", fields: [toUnitId], references: [id])
  toDept          String?
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Float
  reason          String?
  status          TransferStatus @default(PENDING)
  requestedById   String
  requestedBy     User           @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?          @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  completedAt     DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}

// ──── VEHICLE REGISTER (logistics) ────
// Pool of vehicles used to dispatch OUTWARD gate passes (Local Job + Outside).
// Each gate pass references one vehicle; the vehicle's trip history is the set
// of gate passes assigned to it.
model Vehicle {
  id                String        @id @default(uuid())
  regNumber         String        @unique // KA01AB1234
  vehicleType       String? // truck / van / pickup / car / bike
  make              String?
  model             String?
  capacityKg        Float?
  ownerType         String? // OWNED | HIRED
  driverName        String?
  driverPhone       String?
  insuranceExpiry   DateTime?
  pucExpiry         DateTime?
  fitnessExpiry     DateTime?
  rcUrl             String? // optional RC scan
  status            VehicleStatus @default(ACTIVE)
  notes             String?
  createdById       String
  createdBy         User          @relation("VehicleCreator", fields: [createdById], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  gatePasses        GatePass[]    @relation("GatePassVehicle")
  // Drivers whose default/preferred vehicle is this one.
  defaultForDrivers Driver[]      @relation("DriverDefaultVehicle")
  trips             VehicleTrip[]
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// Driver register — mirrors Vehicle. A driver may be the default for one vehicle,
// but on any given trip the dispatcher can pair any driver with any vehicle.
model Driver {
  id               String       @id @default(uuid())
  name             String
  phone            String?
  licenseNo        String?      @unique
  licenseExpiry    DateTime?
  // Optional pointer to the vehicle this driver usually drives. Just a hint
  // for the dispatch UI — the dispatcher can override per trip.
  defaultVehicleId String?
  defaultVehicle   Vehicle?     @relation("DriverDefaultVehicle", fields: [defaultVehicleId], references: [id])
  status           DriverStatus @default(ACTIVE)
  notes            String?
  createdById      String
  createdBy        User         @relation("DriverCreator", fields: [createdById], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  gatePasses GatePass[]    @relation("GatePassDriver")
  trips      VehicleTrip[]

  @@index([defaultVehicleId])
}

enum DriverStatus {
  ACTIVE
  INACTIVE
}

// A VehicleTrip is one physical dispatch of one vehicle + (optionally) one driver.
// It may carry one or more gate-passes (units pooling consignments into the
// same vehicle), or zero gate-passes (ad-hoc movement — e.g., admin errand,
// vendor pickup, owner travel — still logged for traceability).
model VehicleTrip {
  id              String  @id @default(uuid())
  tripNumber      String  @unique // RAPS/TRIP/<FY>/<N>
  vehicleId       String
  vehicle         Vehicle @relation(fields: [vehicleId], references: [id])
  driverId        String?
  driver          Driver? @relation(fields: [driverId], references: [id])
  // Snapshot fields — captured at dispatch time so trip history stays accurate
  // even if the Vehicle/Driver record is later edited.
  driverNameSnap  String?
  driverPhoneSnap String?
  vehicleRegSnap  String?

  // Ad-hoc fields — populated when the trip carries no gatepasses.
  purpose     String?
  destination String?

  dispatchedAt   DateTime?
  dispatchedById String?
  dispatchedBy   User?     @relation("VehicleTripDispatcher", fields: [dispatchedById], references: [id])
  returnedAt     DateTime?
  returnedById   String?
  returnedBy     User?     @relation("VehicleTripReturner", fields: [returnedById], references: [id])

  status  TripStatus @default(SCHEDULED)
  remarks String?

  createdById String
  createdBy   User     @relation("VehicleTripCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gatePasses GatePass[] @relation("TripGatePasses")

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
}

enum TripStatus {
  SCHEDULED
  IN_TRANSIT
  RETURNED
  CANCELLED
}

// ──── WORK ORDERS (SUPPLY_CHAIN drafts → ADMIN accepts → UNIT executes) ────
// Doc No: RAPS/WO/01. Mirrors the printable Work Order form (ION header).
// SUPPLY_CHAIN records the customer's external Supply Order + drafts a Work Order.
// ADMIN reviews + accepts (acceptance form). On acceptance the WO is assigned to
// a unit; that unit's MANAGER accepts and starts execution. Delivery progress is
// tracked via per-invoice qty entries; on-time % is computed from PDC (latest
// extension wins) vs. completion date.
model WorkOrder {
  id              String  @id @default(uuid())
  // Auto-generated internal Work Order number — RAPS/WO/<FY>/<N>
  workOrderNumber String  @unique
  // ION header number on the printable form — RAPS/<UNIT>/<FY>/<N>. Auto.
  ionNumber       String? @unique

  // ── External Supply Order (customer's reference) ──
  supplyOrderNo          String
  supplyOrderDate        DateTime
  supplyOrderDescription String?
  // Short name / description of the item under the supply order.
  nomenclature           String?

  // ── Customer ──
  customerName    String
  customerContact String?

  // ── Order details ──
  orderQuantity  Float
  orderUnit      String   @default("Nos")
  pdcDate        DateTime // Primary delivery commitment date
  deliveryClause String?
  // Supply Chain declares up-front how many delivery lots this WO will be split
  // into (1 = single shot, N = batch deliveries). Drives "Lot X of N sent"
  // progress badge and gates "Open Lot" once that many lots have been opened.
  lotsExpected   Int?

  // Delivery progress notes (filled by Supply Chain or Accounts).
  deliveryDetails            String?
  deliveryDetailsUpdatedAt   DateTime?
  deliveryDetailsUpdatedById String?
  deliveryDetailsUpdatedBy   User?     @relation("WorkOrderDeliveryUpdater", fields: [deliveryDetailsUpdatedById], references: [id])

  // ── Scope / specs ──
  fimDetails             String?
  inspectionAgency       String?
  qapNo                  String?
  drawingsDetails        String?
  processDrawingsDetails String?
  toolingScope           String? // RAPS scope / Customer scope
  packingDetails         String?
  transportationDetails  String?
  majorWorksAtSite       String? // e.g. "Unit-5"
  projectCoordinator     String?
  otherInformation       String?
  orderTermsAndScope     String?
  remarks                String?

  // ── Bank Guarantee (latest values; full history in WorkOrderBgEntry) ──
  bankGuaranteeNo   String?
  bankGuaranteeDate DateTime?

  // ── Insurance (latest values; full history in WorkOrderInsuranceEntry) ──
  insuranceNo   String?
  insuranceDate DateTime?

  // ── Unit assignment + acceptance ──
  assignedUnitId     String?
  assignedUnit       Unit?     @relation("WorkOrderAssignedUnit", fields: [assignedUnitId], references: [id])
  // Free-text unit/location from the source sheet (e.g. "SHAR", "CPDC-Rubber
  // Lining") when it doesn't match any Unit record. Shown in the UI in place
  // of "Unassigned" until a real unit is assigned.
  assignedUnitName   String?
  unitAcceptedAt     DateTime?
  unitAcceptedById   String?
  unitAcceptedBy     User?     @relation("WorkOrderUnitAcceptor", fields: [unitAcceptedById], references: [id])
  unitAcceptanceNote String?

  // ── Admin acceptance (acceptance form sent to admins) ──
  adminAcceptedAt     DateTime?
  adminAcceptedById   String?
  adminAcceptedBy     User?     @relation("WorkOrderAdminAcceptor", fields: [adminAcceptedById], references: [id])
  adminAcceptanceNote String?

  status         WorkOrderStatus         @default(PENDING_ADMIN)
  deliveryStatus WorkOrderDeliveryStatus @default(NOT_STARTED)

  // Aggregated qty trackers (kept in sync from invoices). No monetary tracking
  // — invoices are doc-only references; payment is confirmed in closure cycles.
  deliveredQty Float @default(0)
  invoicedQty  Float @default(0)

  // Set when the unit marks the WO fully delivered. Used for on-time %.
  completedAt DateTime?

  createdById String
  createdBy   User     @relation("WorkOrderCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── 3-month PDC alert — BOTH admin AND the assigned unit manager must each
  // acknowledge with their own remark (extension needed / issues / status).
  // The red blinking alert stays active until both remarks are filed.
  pdc3MonthAckAt           DateTime? // admin's ack
  pdc3MonthAckById         String?
  pdc3MonthAckBy           User?     @relation("WorkOrderPdcAlertAcker", fields: [pdc3MonthAckById], references: [id])
  pdc3MonthAckNote         String?
  pdc3MonthMgrAckAt        DateTime? // unit manager's ack
  pdc3MonthMgrAckById      String?
  pdc3MonthMgrAckBy        User?     @relation("WorkOrderPdcAlertMgrAcker", fields: [pdc3MonthMgrAckById], references: [id])
  pdc3MonthMgrAckNote      String?
  pdc3MonthAlertNotifiedAt DateTime? // stamped by the daily cron once the alert fires, to keep it one-shot

  extensions       WorkOrderExtension[]
  invoices         WorkOrderInvoice[]
  closures         WorkOrderClosure[]
  bgEntries        WorkOrderBgEntry[]
  insuranceEntries WorkOrderInsuranceEntry[]
  alarms           WorkOrderAlarm[]
  // Line items — the materials under this WO. Each has its own qty + UOM and is
  // tracked lot-wise through delivery. orderQuantity/orderUnit above are kept as
  // aggregates (sum of item qty / first item UOM) for back-compat.
  items            WorkOrderItem[]

  @@index([assignedUnitId])
  @@index([status])
  @@index([pdcDate])
}

// One material line under a Work Order. Multiple per WO (S.No, Description,
// Quantity, UOM). Delivered lot-wise — see WorkOrderClosureItem.
model WorkOrderItem {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  lineNo      Int // S.No (1, 2, 3 …)
  description String
  quantity    Float
  uom         String    @default("Nos")

  closureItems WorkOrderClosureItem[]

  @@unique([workOrderId, lineNo])
  @@index([workOrderId])
}

// PDC extension log (Extension 1, 2, ...). Latest extension's newPdcDate is the
// effective PDC for on-time computation.
model WorkOrderExtension {
  id                        String    @id @default(uuid())
  workOrderId               String
  workOrder                 WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  extensionNo               Int
  newPdcDate                DateTime
  reason                    String?
  // PDC extension requires the bank guarantee to be extended too.
  bankGuaranteeExtendedUpto DateTime?
  // Workflow status of the customer-facing request letter and PRC.
  requestLetterStatus       String?
  prcStatus                 String?
  grantedAt                 DateTime  @default(now())
  grantedById               String?
  grantedBy                 User?     @relation("WorkOrderExtensionGranter", fields: [grantedById], references: [id])

  @@unique([workOrderId, extensionNo])
  @@index([workOrderId])
}

// Per-invoice qty log (qty-wise invoice tracking — no monetary amount).
model WorkOrderInvoice {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  invoiceNo   String
  invoiceDate DateTime
  quantity    Float
  remarks     String?
  createdById String?
  createdBy   User?     @relation("WorkOrderInvoiceCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([workOrderId])
}

// Bank Guarantee history. Each row = one BG ever attached to this WO. Newest = active.
model WorkOrderBgEntry {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  bgNo        String
  bgDate      DateTime?
  validUpto   DateTime?
  fileUrl     String?
  fileName    String?
  note        String?
  addedAt     DateTime  @default(now())
  addedById   String?
  addedBy     User?     @relation("WOBgEntryAdder", fields: [addedById], references: [id])

  @@index([workOrderId])
}

// Insurance history. Each row = one insurance policy ever attached to this WO.
model WorkOrderInsuranceEntry {
  id            String    @id @default(uuid())
  workOrderId   String
  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  insuranceNo   String
  insuranceDate DateTime?
  validUpto     DateTime?
  fileUrl       String?
  fileName      String?
  note          String?
  addedAt       DateTime  @default(now())
  addedById     String?
  addedBy       User?     @relation("WOInsuranceEntryAdder", fields: [addedById], references: [id])

  @@index([workOrderId])
}

enum WorkOrderStatus {
  PENDING_ADMIN // Supply Chain logged from customer SO; awaiting admin acceptance
  ADMIN_ACCEPTED // admin accepted; awaiting unit acceptance
  UNIT_ACCEPTED // unit acknowledged; execution begins
  IN_PROGRESS // ≥1 invoice logged
  COMPLETED // delivered qty ≥ order qty
  CLOSED
  CANCELLED
  REJECTED // admin rejected
  ON_HOLD // unit rejected; awaiting reassignment by supply chain/admin
}

enum WorkOrderDeliveryStatus {
  NOT_STARTED
  IN_PROGRESS
  PARTIAL
  DELIVERED
  DELAYED
}

// ──── WORK ORDER LOT (CLOSURE) WORKFLOW ────
// Per delivery lot. Unit manager finishes the lot's work → fills lot details +
// uploads ONE lot report PDF (goes straight to QC) → QC verifies with a
// mandatory remark (or holds the lot) → FINANCE clicks "Invoice Sent" + "DC
// Sent" (both done = 48h ack SLA starts) → FINANCE clicks "Goods Ack" when the
// driver returns the signed receipt (45-day payment window starts) → ACCOUNTS
// follows up weekly and confirms payment → lot CLOSED. When the final lot's
// payment lands and full qty is covered, the WO auto-closes.
enum WorkOrderClosureStage {
  UNIT_DOCS_PENDING // lot report with QC for verification
  QC_VERIFIED // QC approved — Finance must send invoice + DC
  MGMT_APPROVED // legacy stage (old cycles only) — new flow goes QC → Finance directly
  ON_HOLD
  INVOICE_SENT // ← both Invoice Sent + DC Sent clicked; 48h ack SLA running
  DELIVERY_ACKNOWLEDGED // ← goods ack received; 48h SLA stops, 45-day payment window starts
  PAYMENT_RECEIVED // ← Accounts confirmed; lot CLOSED
}

// One closure cycle per delivery batch. Multiple may be open per WO at once.
model WorkOrderClosure {
  id           String                @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  cycleNumber  Int // 1, 2, 3 … (sequential within a WO)
  stage        WorkOrderClosureStage @default(UNIT_DOCS_PENDING)
  deliveryQty  Float // qty covered by this batch
  deliveryNote String?
  deliveredAt  DateTime              @default(now()) // when unit marked the batch delivered
  openedById   String? // unit user who triggered the cycle
  openedBy     User?                 @relation("WOClosureOpener", fields: [openedById], references: [id])

  // Unit submission
  unitDocsSubmittedAt   DateTime?
  unitDocsSubmittedById String?
  unitDocsSubmittedBy   User?     @relation("WOClosureUnitSubmitter", fields: [unitDocsSubmittedById], references: [id])

  // QC verification — remark is mandatory in the new flow and stored here.
  qcVerifiedAt        DateTime?
  qcVerifiedById      String?
  qcVerifiedBy        User?     @relation("WOClosureQCVerifier", fields: [qcVerifiedById], references: [id])
  qcCertificateUrl    String?
  qcCertificateNumber String?
  qcRemark            String?

  // Mgmt L5 approval (sureshbabu / rameshbabu / madhubabu)
  mgmtApprovedAt   DateTime?
  mgmtApprovedById String?
  mgmtApprovedBy   User?     @relation("WOClosureMgmtApprover", fields: [mgmtApprovedById], references: [id])
  mgmtApprovalNote String?

  // Finance — invoice + delivery challan (numbers entered manually, no upload)
  invoiceNumber         String?   @unique // entered by Finance
  deliveryChallanNumber String? // entered by Finance
  invoiceDate           DateTime?
  invoiceDescription    String? // free-text scope description (no amount)
  invoiceFileUrl        String? // deprecated; kept for back-compat with old rows
  invoiceSentAt         DateTime? // ← Finance clicked "Invoice Sent"
  invoiceSentById       String?
  invoiceSentBy         User?     @relation("WOClosureInvoiceSender", fields: [invoiceSentById], references: [id])
  // Finance clicked "DC Sent". 48h SLA starts only when BOTH buttons are done.
  dcSentAt              DateTime?
  dcSentById            String?
  dcSentBy              User?     @relation("WOClosureDcSender", fields: [dcSentById], references: [id])
  slaDeadlineAt         DateTime? // = when both invoice + DC sent, + 48h
  last24hReminderAt     DateTime?
  slaBreachedAt         DateTime?

  // Finance delivery acknowledgement — stops 48h SLA and starts 45-day payment
  // window. Both ack flags must be set true before deliveryAckAt is stamped.
  invoiceAckReceived   Boolean   @default(false)
  invoiceAckAt         DateTime?
  dcAckReceived        Boolean   @default(false)
  dcAckAt              DateTime?
  deliveryAckAt        DateTime?
  deliveryAckById      String?
  deliveryAckBy        User?     @relation("WOClosureDeliveryAcker", fields: [deliveryAckById], references: [id])
  deliveryAckNote      String?
  deliveryAckSignedUrl String? // optional URL to the customer-signed receipt scan

  // 45-day payment window (starts at deliveryAckAt). Accounts monitor and
  // log weekly customer follow-ups until payment is received.
  paymentDueAt         DateTime? // = deliveryAckAt + 45 days
  paymentDelayedAt     DateTime? // set by background job when paymentDueAt has passed without payment
  lastWeeklyReminderAt DateTime?

  // Accounts — payment confirmation closes the cycle
  paymentReceivedAt   DateTime?
  paymentReceivedById String?
  paymentReceivedBy   User?     @relation("WOClosurePaymentLogger", fields: [paymentReceivedById], references: [id])
  paymentNote         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  docs            WorkOrderClosureDoc[]
  holdRequests    WorkOrderHoldRequest[]
  weeklyFollowups WorkOrderClosureWeeklyFollowup[]
  // Per-item quantities dispatched in this lot. deliveryQty above is the
  // aggregate sum of these rows (kept for back-compat).
  items           WorkOrderClosureItem[]

  @@unique([workOrderId, cycleNumber])
  @@index([workOrderId])
  @@index([stage])
  @@index([slaDeadlineAt])
  @@index([paymentDueAt])
}

// Quantity of a single WO line item dispatched within one lot/closure.
model WorkOrderClosureItem {
  id          String           @id @default(uuid())
  closureId   String
  closure     WorkOrderClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  itemId      String
  item        WorkOrderItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  deliveryQty Float

  @@unique([closureId, itemId])
  @@index([closureId])
  @@index([itemId])
}

// Individual documents attached during a closure cycle.
model WorkOrderClosureDoc {
  id           String                @id @default(uuid())
  closureId    String
  closure      WorkOrderClosure      @relation(fields: [closureId], references: [id], onDelete: Cascade)
  docType      String // WORK_COMPLETION_REPORT, TEST_REPORT, AS_BUILT_DRAWING, DISPATCH_CHECKLIST, COMPLETION_PHOTOS, QC_VERIFICATION_CERTIFICATE, INVOICE, HOLD_CHECKLIST, RECEIPT_PROOF
  fileUrl      String
  fileName     String
  stage        WorkOrderClosureStage
  uploadedAt   DateTime              @default(now())
  uploadedById String
  uploadedBy   User                  @relation("WOClosureDocUploader", fields: [uploadedById], references: [id])
  note         String?

  @@index([closureId])
  @@index([docType])
}

// Each time QC/Finance/Admin sends a cycle back on HOLD with missing items.
model WorkOrderHoldRequest {
  id           String           @id @default(uuid())
  closureId    String
  closure      WorkOrderClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  raisedAt     DateTime         @default(now())
  raisedById   String
  raisedBy     User             @relation("WOHoldRaiser", fields: [raisedById], references: [id])
  missingItems Json // [{ docType, note }, ...]
  reason       String?
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?            @relation("WOHoldResolver", fields: [resolvedById], references: [id])
  resolvedNote String?

  @@index([closureId])
}

// ──── WORK ORDER ALARMS ────
// Operational alerts surfaced on the WO row (and the WO detail page). A daily
// cron computes which alarm types apply (PDC near/overdue, lot stuck at QC,
// 48h SLA breach, payment due/overdue, BG expiring, lot on hold) and inserts
// new ACTIVE rows. Users can append remarks at any time (WorkOrderAlarmNote)
// and acknowledge/resolve to clear the badge. Each transition stores its own
// remark — full audit trail preserved.
enum WorkOrderAlarmType {
  PDC_NEAR // PDC within 90 days
  PDC_OVERDUE // PDC passed, WO not completed
  LOT_QC_PENDING // Lot stuck at UNIT_DOCS_PENDING > 7 days
  LOT_ON_HOLD // Lot in ON_HOLD stage
  SLA_BREACH_48H // Invoice sent > 48h, no delivery ack
  PAYMENT_DUE_SOON // ≤ 7 days remaining on 45-day window
  PAYMENT_OVERDUE // 45 days passed, no payment
  BG_EXPIRING // Bank Guarantee valid-upto ≤ 30 days
}

enum WorkOrderAlarmSeverity {
  INFO
  WARNING
  CRITICAL
}

enum WorkOrderAlarmStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

model WorkOrderAlarm {
  id             String                 @id @default(uuid())
  workOrderId    String
  workOrder      WorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  closureId      String? // optional — alarms tied to a specific lot/cycle
  type           WorkOrderAlarmType
  severity       WorkOrderAlarmSeverity
  status         WorkOrderAlarmStatus   @default(ACTIVE)
  title          String
  // Initial trigger context (computed when the alarm fires).
  triggerContext String?

  createdAt DateTime @default(now())

  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?     @relation("WOAlarmAcker", fields: [acknowledgedById], references: [id])
  ackRemark        String?

  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?     @relation("WOAlarmResolver", fields: [resolvedById], references: [id])
  resolveRemark String?

  notes WorkOrderAlarmNote[]

  // Prevent duplicate ACTIVE alarms of the same kind for the same scope.
  // closureId is part of the key so per-lot alarms can coexist with WO-level.
  @@unique([workOrderId, closureId, type, status])
  @@index([workOrderId])
  @@index([status])
  @@index([type])
}

// Append-only note thread per alarm. Stores every comment/remark with author +
// timestamp. The acknowledge/resolve remark is also mirrored here so the
// timeline is complete in one query.
model WorkOrderAlarmNote {
  id        String         @id @default(uuid())
  alarmId   String
  alarm     WorkOrderAlarm @relation(fields: [alarmId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation("WOAlarmNoteAuthor", fields: [authorId], references: [id])
  body      String
  // Optional marker for system-generated rows (e.g. "Acknowledged", "Resolved")
  // vs. plain user comments.
  kind      String? // COMMENT | ACK | RESOLVE | SYSTEM
  createdAt DateTime       @default(now())

  @@index([alarmId])
}

// Weekly follow-up record raised inside the 45-day post-delivery payment window.
// Accounts/Admin click the flashing weekly reminder, contact the customer, then
// log the response + remark here. A new entry is created for each week the
// cycle remains in DELIVERY_ACKNOWLEDGED stage.
model WorkOrderClosureWeeklyFollowup {
  id               String           @id @default(uuid())
  closureId        String
  closure          WorkOrderClosure @relation(fields: [closureId], references: [id], onDelete: Cascade)
  weekNumber       Int // 1, 2, 3 … (sequential within a cycle)
  contactedAt      DateTime         @default(now())
  contactedById    String
  contactedBy      User             @relation("WOClosureWeeklyFollowupContact", fields: [contactedById], references: [id])
  customerResponse String? // what the customer said
  note             String? // internal remark
  createdAt        DateTime         @default(now())

  @@index([closureId])
}

// ──── METROLOGY / CALIBRATION ITEMS ────
// One row per piece of equipment that Metrology calibrates. Categorised by
// equipment kind so the UI can route each list to its dedicated page.
// Write access is restricted to METROLOGY + ADMIN; all other procurement-chain
// roles see read-only listings.
model CalibrationItem {
  id                     String              @id @default(uuid())
  category               CalibrationCategory
  mmrSubCategory         MmrSubCategory? // only meaningful when category = MMR
  mirNo                  String?
  mirDate                DateTime?
  name                   String // e.g. "Pressure Gauge", "Vernier Caliper"
  make                   String?
  model                  String?
  serialNo               String?
  rapsplSerialNo         String?
  operatingRange         String? // e.g. "0-400 Kg/Cm²"
  capacityMin            String? // for weighing balances
  capacityMax            String? // for weighing balances
  leastCount             String?
  unitLocation           String? // UNIT-I, UNIT-II, UNIT-III, UNIT-V, UNIT-S, Store, etc.
  usedFor                String? // e.g. "Hydraulic Press-I", "Autoclave"
  calibrationOn          DateTime?
  calibrationDueDate     DateTime?
  recallDueDate          DateTime?
  calibrationCertificate String?
  periodicity            String              @default("Every One Year")
  notes                  String?
  remarks                String?
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  records                CalibrationRecord[]

  @@index([category])
  @@index([mmrSubCategory])
  @@index([unitLocation])
}

// Per-fiscal-year calibration history rows shown side-by-side in the register
// (FY 26-27, FY 27-28, …). Each holds the QC verifier, calibration dates,
// certificate number and optional uploaded certificate PDF for that year.
model CalibrationRecord {
  id                    String          @id @default(uuid())
  itemId                String
  item                  CalibrationItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fiscalYear            String // "FY 26-27"
  qcVerifiedBy          String?
  verifiedOn            DateTime?
  certificateNo         String?
  certificateAttachment String? // public URL to uploaded PDF
  calibratedOn          DateTime?
  dueDate               DateTime? // calibration due date
  recallDate            DateTime? // recall date (separate from calibration due date)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([itemId, fiscalYear])
  @@index([itemId])
}

enum CalibrationCategory {
  PRESSURE_GAUGE
  VACUUM_GAUGE
  WEIGHING_BALANCE
  TESTING_EQUIPMENT
  METROLOGY_INSTRUMENT
  MMR // Monitoring & Measuring Resources — thermocouples / temperature controllers
}

// Sub-category buckets used when filtering Monitoring & Measuring Resources
// from the universal MMR search.
enum MmrSubCategory {
  PRESSURE_GAUGES
  VACUUM_GAUGES
  METROLOGY_INSTRUMENTS
  LAB_TESTING_EQUIPMENT
  AUTOCLAVE_OVEN_THERMOCOUPLES
  EOT_CRANES_CHAIN_BLOCKS
  WEIGHING_BALANCES
  NDT
  OTHER
}

// ──── NOTIFICATIONS ────
model Notification {
  id           String   @id @default(uuid())
  type         String
  title        String
  message      String
  productId    String?
  targetRole   String?
  targetUserId String?
  targetUser   User?    @relation("TargetUser", fields: [targetUserId], references: [id])
  sentById     String?
  sentBy       User?    @relation("SentBy", fields: [sentById], references: [id])
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// One row per browser/device a user enabled push notifications on.
// endpoint is the unique push-service URL; dead endpoints (410/404 from the
// push service) are pruned automatically by the push sender.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────
// Team Chat — the in-house messaging channel shown on every dashboard.
// Replaces ad-hoc WhatsApp coordination. A message is either a broadcast
// (`@everyone`, isBroadcast = true, recipientId null) seen by all users, or a
// direct message (`@username`, recipientId set) seen only by sender + recipient.
// Soft-deleted by the sender once the work is done (deletedAt set): the row
// stays for the "deleted history" view but drops out of the active feed.
// ──────────────────────────────────────────────────────────────
model Message {
  id          String    @id @default(uuid())
  body        String
  senderId    String
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  isBroadcast Boolean   @default(false)
  recipientId String?
  recipient   User?     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  // Work closure: only the recipient of a direct message can set this. Once set,
  // the work is "done" and the sender is allowed to delete the message. Broadcasts
  // never carry a doneAt (there is no single recipient to close them).
  doneAt      DateTime?
  // Soft delete: only the sender can set this; row is retained for history.
  // A direct message can only be deleted after the recipient marks it done.
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([isBroadcast, createdAt])
  @@index([recipientId, createdAt])
  @@index([senderId, createdAt])
}

// ──────────────────────────────────────────────────────────────
// Machinery register (master list of every machine on the shop floor)
// Owned by Safety; Unit-5 users also have edit rights. Everyone else views.
// AMC = Annual Maintenance Contract — status text + optional attachment.
// ──────────────────────────────────────────────────────────────
model Machinery {
  id              String    @id @default(uuid())
  serialNumber    Int // S. No (display ordering)
  name            String // Name of Machinery / Equipment
  capacity        String? // Capacity / Size (multiline OK)
  makeModel       String? // Make & Model
  machineSerialNo String? // Serial No printed on the machine
  rapsId          String    @unique // RAPS ID No (e.g. RAMS/HP-01/LM/01)
  place           String? // Place of Machine (Unit-1, Unit-5, Unit-1A …)
  remarks         String?
  amcStatus       String? // ACTIVE / EXPIRED / NA / free-text
  amcVendor       String?
  amcExpiry       DateTime?
  amcAttachment   String? // /uploads/amc-docs/…
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String?
  createdBy       User?     @relation("MachineryCreator", fields: [createdById], references: [id])

  @@index([serialNumber])
  @@index([place])
}

// ──────────────────────────────────────────────────────────────
// Fire Extinguisher register (separate tab on the Machinery page)
// Same access rules as Machinery.
// ──────────────────────────────────────────────────────────────
model FireExtinguisher {
  id           String    @id @default(uuid())
  serialNumber Int // Ser No within the unit list
  type         String // "Dry Powder ABC" / "Carbon Dioxide"
  capacity     String // "4 Kgs" / "6 Kgs" / "4.5 Kgs"
  rapsId       String    @unique // RAMS/ABC-01/FE-01
  refilledOn   DateTime?
  nextDueOn    DateTime?
  unit         String // Unit-1, Unit-2, …
  location     String? // free-text install spot
  attachment   String? // /uploads/amc-docs/…
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?
  createdBy    User?     @relation("FireExtinguisherCreator", fields: [createdById], references: [id])

  @@index([unit])
  @@index([nextDueOn])
}

// ──────────────────────────────────────────────────────────────
// HR / Training domain
//   • Employee — master register independent of login Users. Most operators
//     don't need ERP accounts but still appear in the skill matrix / training
//     records.
//   • SkillMatrix — fixed-column 1-4 (+ NA) self/manager rating per employee,
//     plus a free-text training-needs note. One row per employee.
//   • TrainingPlan — per fiscal year (e.g. "2026-27"). HR opens it, unit
//     Managers can append their team's training items.
//   • TrainingPlanItem — one training topic in the plan.
//   • TrainingSession — actual delivery record (date, faculty, place, subject).
//     Optionally linked back to a plan item.
//   • TrainingAttendee — one row per attendee on a session: evaluation
//     details + evaluation date + per-attendee sign file.
// ──────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

model Employee {
  id            String         @id @default(uuid())
  empCode       String         @unique // e.g. "RAPSPL-3"
  serialNo      Int // running S.No in the printed register
  name          String
  designation   String?
  qualification String?
  experience    Int? // years
  category      String? // "QA-QC" / "Production UNIT 1" / "Adminstration" …
  department    String? // free-text fallback when category isn't enough
  phone         String?
  email         String?
  dateOfJoining DateTime?
  status        EmployeeStatus @default(ACTIVE)
  notes         String?

  // Optional link if this employee also has an ERP login account.
  userId String? @unique
  user   User?   @relation("EmployeeAccount", fields: [userId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("EmployeeCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillMatrix      SkillMatrix?
  trainingAttended TrainingAttendee[]

  @@index([category])
  @@index([status])
  @@index([serialNo])
}

// Skill levels are stored 0-4 where 0 = "N.A." and 1-4 is the rating. Using
// Float to allow the 3.5 half-step the latest sheet uses.
model SkillMatrix {
  id         String   @id @default(uuid())
  employeeId String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // 16 fixed skill area columns (mirrors the Excel — change with a migration
  // if/when the org adds/removes a skill).
  qmsAwareness           Float?
  risksOpportunities     Float?
  processKnowledge       Float?
  inspectionTesting      Float?
  qualityAnalytical      Float?
  nonconformityAnalysis  Float?
  customerRelations      Float?
  supplierManagement     Float?
  projectPlanning        Float?
  equipmentMaintenance   Float?
  materialInventory      Float?
  internalAuditing       Float?
  crisisManagement       Float?
  communicationSkills    Float?
  interPersonalRelations Float?

  trainingNeeds String? // free-text "Risks & opportunities, Internal auditing"
  remarks       String?
  headOfDeptSig String? // signature image / pdf url
  ratedOn       DateTime? // when this rating was last given

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model TrainingPlan {
  id         String             @id @default(uuid())
  fiscalYear String             @unique // "2026-27"
  title      String // "Annual Training Plan FY 2026-27"
  reference  String? // "F.No. RAMS/ATP/00, Dt. 06-04-2026"
  preparedBy String?
  approvedBy String?
  status     TrainingPlanStatus @default(DRAFT)

  createdById String
  createdBy   User     @relation("TrainingPlanCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items    TrainingPlanItem[]
  sessions TrainingSession[]

  @@index([status])
}

enum TrainingItemStatus {
  PLANNED // entered in the plan but not yet held
  SCHEDULED // date locked
  COMPLETED // session done
  CANCELLED
}

model TrainingPlanItem {
  id             String             @id @default(uuid())
  planId         String
  plan           TrainingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  serialNo       Int // running # in the plan
  subject        String // "AS 9100D Requirements – QMS"
  participants   String // free-text list of names / "All staff"
  faculty        String? // "External (K. Vijaya Krishna)"
  scheduledMonth String? // "Nov 2026 for 01 day @ 3 hrs"
  actualMonth    String? // filled when held
  hoursPerMonth  Float?
  remarks        String?
  status         TrainingItemStatus @default(PLANNED)

  // The unit / dept this item is tagged to. Managers can add items for
  // their own unit; HR sees everything.
  unitId   String?
  unit     Unit?   @relation("TrainingPlanItemUnit", fields: [unitId], references: [id], onDelete: SetNull)
  category String? // free-text dept tag if no unit

  createdById String
  createdBy   User     @relation("TrainingPlanItemCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions TrainingSession[]

  @@index([planId])
  @@index([unitId])
  @@index([status])
}

model TrainingSession {
  id            String            @id @default(uuid())
  sessionNumber String            @unique // auto e.g. "TS-2026-0001"
  planId        String?
  plan          TrainingPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  planItemId    String?
  planItem      TrainingPlanItem? @relation(fields: [planItemId], references: [id], onDelete: SetNull)

  subject          String // "Lab testing chemical analysis and reporting"
  trainingDateFrom DateTime
  trainingDateTo   DateTime? // null when single-day
  duration         String? // "5 days @ 2hrs/day"
  place            String? // "Unit-2"
  faculty          String // "P. Ashok Babu"
  facultySign      String? // file url
  reference        String? // "F. No. RAMS/TAER, Rev.00 Dt. 10-11-2023"

  // Per-session uploads
  trainingNotesUrl String?
  evaluationUrl    String?
  feedbackUrl      String?
  notes            String?

  createdById String
  createdBy   User     @relation("TrainingSessionCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendees TrainingAttendee[]

  @@index([planId])
  @@index([planItemId])
  @@index([trainingDateFrom])
}

model TrainingAttendee {
  id                String          @id @default(uuid())
  sessionId         String
  session           TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  signUrl           String? // attendee sign image
  evaluationDetails String? // "Awareness about preparation of reports …"
  dateOfEvaluation  DateTime?
  evaluatedBy       String? // free-text or signature url
  createdAt         DateTime        @default(now())

  @@unique([sessionId, employeeId])
  @@index([employeeId])
}

// ──── ATTENDANCE REGISTER ────
// Unit-scoped monthly attendance maintained by each unit's MANAGER.
// Editing access (employees + day cells + month submission) is restricted to
// the manager of that unit. ADMIN, SAFETY, and ACCOUNTING (after submission)
// can view the data but never see the per-cell modification trail —
// `modifiedAt`/`modifiedBy`/`history` are stripped server-side for non-managers.
model AttendanceEmployee {
  id       String  @id @default(uuid())
  unitId   String
  unit     Unit    @relation(fields: [unitId], references: [id])
  serialNo Int // SL NO in the register
  name     String
  empCode  String? // "E.ID" column
  isActive Boolean @default(true)

  createdById String
  createdBy   User     @relation("AttEmpCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries AttendanceEntry[]

  @@unique([unitId, serialNo])
  @@index([unitId, isActive])
}

// One row per (employee, calendar day). Either a punched IN/OUT pair OR a
// status code is stored — `statusCode` covers leave / holiday / off-site
// values like "L", "HYD", "BAKRID", "H".
model AttendanceEntry {
  id         String             @id @default(uuid())
  employeeId String
  employee   AttendanceEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime           @db.Date

  inTime     String? // "HH:mm" — stored as text to dodge timezone math
  outTime    String? // "HH:mm"
  statusCode String? // "L", "HYD", "BAKRID", "H" …

  // Audit trail for manager edits. The icon shown to managers under a cell
  // lights up whenever this entry has been modified after first save.
  // Stripped from the API response for ADMIN/SAFETY/ACCOUNTING viewers.
  firstSavedAt   DateTime  @default(now())
  modifiedAt     DateTime?
  modifiedById   String?
  modifiedByName String?
  history        Json? // [{ at, byId, byName, from, to }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

// One row per (unit, year, month) when the manager clicks "Send to Accounts".
// Accounts can see / pull monthly summaries only for months that have a row
// here, keyed by (unitId, year, month).
model AttendanceMonthSubmission {
  id            String   @id @default(uuid())
  unitId        String
  unit          Unit     @relation(fields: [unitId], references: [id])
  year          Int
  month         Int // 1..12
  submittedAt   DateTime @default(now())
  submittedById String
  submittedBy   User     @relation("AttMonthSubmitter", fields: [submittedById], references: [id])

  @@unique([unitId, year, month])
  @@index([year, month])
}

// ──── KPI-QMS CERTIFICATIONS ────
// Company certifications (ISO etc.) shown read-only on every dashboard's
// KPI-QMS panel. Only Unit-5 users (and SUPERADMIN) upload/replace/delete;
// mirrors the Machinery-register Unit-5 detection.
model QmsCertification {
  id            String    @id @default(uuid())
  title         String // e.g. "ISO 9001:2015"
  certificateNo String?
  issuedBy      String? // certification body
  validFrom     DateTime?
  validTill     DateTime?
  fileUrl       String? // uploaded certificate (PDF/image)
  fileName      String?
  notes         String?
  uploadedById  String?
  uploadedBy    User?     @relation("QmsCertUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ──── QMS DOCUMENTS (SOPs + Work Instructions) ────
// Document library on the QMS hub. Everyone views; only Unit-5 users
// (and SUPERADMIN) upload/replace/delete — same gate as certifications.
model QmsDocument {
  id           String   @id @default(uuid())
  category     String // "SOP" | "WORK_INSTRUCTION"
  title        String
  docNo        String?
  revision     String?
  fileUrl      String?
  fileName     String?
  notes        String?
  uploadedById String?
  uploadedBy   User?    @relation("QmsDocUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ──────────────────────────────────────────────────────────────
// Personal Calendar — private per-user events / reminders.
// Each row is owned by one user; nobody else can see it.
// Recurrence stored on the base row (NONE/DAILY/WEEKLY/MONTHLY/YEARLY
// + optional recurUntil). Occurrences are expanded on read within the
// requested date window — no per-occurrence rows. Editing/deleting a
// recurring event affects the whole series (v1).
// ──────────────────────────────────────────────────────────────
model CalendarEvent {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation("CalendarOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean   @default(false)
  category    String? // label, e.g. "Work" / "Personal"
  color       String    @default("blue") // palette token (blue/green/red/amber/purple/pink/teal/gray)
  visibility  String    @default("PERSONAL") // PERSONAL (owner-only) | EVERYONE (shared, read-only to others)
  recurrence  String    @default("NONE") // NONE | DAILY | WEEKLY | MONTHLY | YEARLY
  recurUntil  DateTime? // inclusive last date a recurring event may fire
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId, startAt])
}

// ──────────────────────────────────────────────────────────────
// MATERIAL INWARD REGISTER (MIR)
// The single, unified inward record kept by Stores. One row = one material
// line received at the store. It can be raised against a Purchase Order
// (pulling PR / supplier / item / issued-to) or stand alone as a direct /
// cash purchase. Each row carries its own self-contained QC flow:
//   DRAFT → QC_REQUESTED → QC_IN_REVIEW → QC_DONE → INWARDED
// Stock (ProductBatch + StockMovement) is created only on the final INWARD
// step. The MIV no. column is NOT stored here — it is derived at read time
// by matching this row's batchNo to the batch a unit later draws via its MIV.
// FK columns are kept as plain ids (no Prisma relations) so this table is
// fully additive and needs no back-relation edits on existing models.
// ──────────────────────────────────────────────────────────────
model MaterialInwardRegister {
  id             String   @id @default(uuid())
  mirNo          String   @unique // RAPS/MIR/<FY>/<N> — auto
  inwardDate     DateTime @default(now())
  vehicleDetails String?

  // Invoice / Cash purchase / Delivery challan / Gate pass + its number
  docType   InwardDocType @default(INVOICE)
  docNumber String?
  // Stores-uploaded supporting documents (invoice / DC / test report / COA …).
  // Array of { label, name, url, uploadedAt, uploadedById }.
  documents Json?

  // Source PO (optional). Snapshot fields are copied at creation so the row
  // stays readable even if the PO later changes.
  purchaseOrderId     String?
  purchaseOrderItemId String?
  supplierName        String?
  prNumbers           String? // comma-joined PR numbers from the PO
  itemDescription     String?
  uom                 String?
  qtyReceived         Float?
  productId           String? // resolved product (for stock + MIV match)

  // Where the material is bound for — derived from the PO's PR(s). A union PO
  // may map to several units; issuedToLabel holds the joined, human label.
  // issuedToDept is set when the PR was raised by a non-unit department role.
  issuedToUnitId String?
  issuedToDept   String?
  issuedToLabel  String?
  // Indenter — whoever raised the PR (the requester the material is for).
  // Snapshotted from the PO's PR manager at creation; null for direct entries
  // or PRs with no recorded raiser.
  indenterId     String?
  indenterName   String?

  // Per-unit allocation for this PO line. For a non-union PO this is the single
  // PR's unit; for a union PO it splits the line across every unit that raised a
  // PR for the material (from PurchaseOrderItemAllocation). Empty when the PR was
  // raised by a department/global role (no unit). Drives the per-unit stock split
  // at inward. Array of { unitId, unitName, unitCode, allocatedQty }.
  unitAllocations Json?

  // Sequential lot number per PO (Lot 1, 2, 3 … N). Each partial receipt against
  // the same PO is its own lot; null for direct/cash entries with no PO.
  lotNo Int?

  purpose      String?
  batchNo      String?
  dateOfExpiry DateTime?

  status InwardStatus @default(DRAFT)

  // Inward Inspection ION No. — auto-generated when Stores sends the lot to QC
  // (RAPS/IION/<FY>/<N>). Stores never controls/edits it.
  ionNo String? @unique

  // QC request — filled by Stores when handing the lot to QC.
  qcRequestedAt    DateTime?
  qcRequestedById  String?
  qcRequestNote    String?
  qcDocRequirement String? // COA / COC / Test report / etc. (comma-joined list)
  // The inward-inspection request form Stores reviews before sending to QC:
  // packing condition on receipt, documents enclosed checklist, stores remark.
  // Auto-filled header fields come from the row itself; this holds the extras.
  qcRequest        Json?

  // QC review — filled by QC.
  qcReviewerId      String?
  qcReviewStartedAt DateTime?
  qcResult          QCResult?
  qtyAccepted       Float?
  qtyRejected       Float?
  qtyHeld           Float?
  qcReportNo        String? // Inward Inspection No. — entered/confirmed by QC
  qcReportRemark    String?

  // Hold + re-inspection. When QC puts a lot ON_HOLD (e.g. pending docs / retest)
  // the reason is captured here and the lot can be resent to QC. Each completed
  // review round (including holds) is appended to qcHistory before the next round
  // so nothing is lost across re-inspections. qcRound counts the current round.
  holdReason   String?
  holdCount    Int       @default(0)
  qcRound      Int       @default(1)
  qcHistory    Json? // [{ round, result, reportNo, remark, reviewerId, finishedAt, holdReason, qtyAccepted, qtyRejected }]
  // Full inward-inspection report (the complete IIR form QC fills): material
  // description/category, document types, packing condition, DOM, qty as-per-PR
  // / ordered, rejection reason, etc. Summary qty/result fields above stay
  // first-class for the register columns + stock logic.
  qcReport     Json?
  qcFinishedAt DateTime?

  // Inward completion — stock created.
  inwardedAt DateTime?
  batchId    String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
  @@index([productId])
  @@index([batchNo])
}

enum InwardDocType {
  INVOICE
  CASH_PURCHASE
  DELIVERY_CHALLAN
  GATE_PASS
}

enum InwardStatus {
  DRAFT
  QC_REQUESTED
  QC_IN_REVIEW
  QC_DONE
  ON_HOLD
  INWARDED
}
