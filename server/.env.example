# --- Database (RDS Postgres in production, Supabase pooler in dev is fine too) ---
# Production RDS example:
# DATABASE_URL="postgresql://rapsadmin:STRONG_PASSWORD@raps-prod.xxxx.ap-south-1.rds.amazonaws.com:5432/raps?schema=public"
# DIRECT_URL="postgresql://rapsadmin:STRONG_PASSWORD@raps-prod.xxxx.ap-south-1.rds.amazonaws.com:5432/raps?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# --- Auth (generate strong random strings — `openssl rand -hex 64`) ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"

# --- Server ---
PORT=4000
NODE_ENV="production"

# Frontend origin for CORS — your domain in prod
CLIENT_URL="https://erp.yourdomain.com"
