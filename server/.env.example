# --- Database (Postgres) ---
# In production, deploy/bootstrap.sh writes this pointing at a localhost Postgres on the EC2 box.
# For local dev, point at any Postgres you have running locally.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# --- Auth (generate strong random strings — `openssl rand -hex 64`) ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"

# --- Server ---
PORT=4000
NODE_ENV="production"

# Frontend origin for CORS — your domain in prod
CLIENT_URL="https://erp.yourdomain.com"

# --- Web Push (VAPID) — generate once with `npx web-push generate-vapid-keys` ---
# Changing these invalidates every existing browser push subscription.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# --- Backups (only used in production by the SUPERADMIN Backups page) ---
# S3 bucket where deploy/backup.sh writes nightly tarballs.
# In production, deploy/bootstrap.sh sets this to raps-backups-<aws-account-id>.
S3_BACKUP_BUCKET=""
AWS_REGION="ap-south-1"
